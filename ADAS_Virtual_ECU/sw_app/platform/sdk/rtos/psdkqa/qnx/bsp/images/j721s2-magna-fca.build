###################################################################################
#
# Neutrino trunk on Magna FCA J7 TDA4VMeco
#
###################################################################################
[-optional]
[+keeplinked]
[image=0x80080000]
[virtual=aarch64le,raw +compress] .bootstrap = {
    # -v causes "debug_flag++" which adds some debugging messages
    # -rADDR,SIZE causes avoid_ram(ADDR,SIZE)
    [+keeplinked] startup-j721s2-magna-fca -v -r0x80000000,0x00080000,1 -r0x90000000,0x30000000,1

    PATH=/proc/boot:/bin:/usr/bin:/sbin:/usr/sbin:/usr/lib
    LD_LIBRARY_PATH=/proc/boot:/lib:/usr/lib:/lib/dll:/lib/dll/pci procnto-smp-instr -v
}

[+script] .script = {
    # Programs require the runtime linker (ldqnx-64.so) to be at a fixed location
    #procmgr_symlink ../../proc/boot/ldqnx-64.so.2 /usr/lib/ldqnx-64.so.2

    display_msg Welcome to QNX Neutrino 7.1.0 on the Magna FCA J7 TDA4VMeco Board!!

    # Ensure that all serial debug and telnet ksh sessions have environment variables set
    ENV=/etc/profile

    # Start some common servers
    slogger2
    pipe &
    dumper -d /tmp

    #######################################################################
    ## Random service
    #######################################################################
    display_msg "Starting random service ..."
    random -t
    # use SA2UL engine to generate random number
    # random -l devr-sa2ul.so:mmra=0x40901000,trng=0x40910000,irq=913
    waitfor /dev/random 5

    #######################################################################
    ## TI SCI / IPC Resource Managers
    #######################################################################
    tisci-mgr
    waitfor /dev/tisci 4
    shmemallocator
    waitfor /dev/shmemallocator 4
    tiipc-mgr
    waitfor /dev/tiipc 4
    tiudma-mgr
    waitfor /dev/tiudma 4
    ipcmgr &

    #######################################################################
    ## UART drivers
    #######################################################################
    display_msg "starting serial driver UART8 (console)"
    devc-seromap -e -F 0x02880000,280
    reopen /dev/ser1
    #display_msg "starting serial driver UART2"
    #devc-seromap -e -F 0x02820000,226

    #######################################################################
    ## I2C driver
    #######################################################################
    #display_msg "starting I2C driver"
    #i2c-omap35xx -p0x2000000 -i232 -d --u0
    #i2c-omap35xx -p0x2010000 -i233 -d --u1
    #i2c-omap35xx -p0x2040000 -i236 -d --u4
    #i2c-omap35xx -p0x2050000 -i237 -d --u5
    #waitfor /dev/i2c5 4

    #######################################################################
    ## RTC utility - requires i2c driver to be running
    #######################################################################
    #display_msg Setting OS clock from RTC
    #rtc hw

    #######################################################################
    ## SD/eMMC memory card driver
    display_msg Starting MMC/SD memory card driver... SD
    devb-sdmmc-am65x blk cache=1m sdio addr=0x04fb0000,irq=36,timing=hs,bs=sscfg=0x8000 cam pnp disk name=sd

    #######################################################################
    ## Network driver
    #######################################################################
    # display_msg "Starting Network driver..."
    #io-pkt-v6-hc -d cpsw2g

    # To support telnet and ftp io-pkt needs to be started before inetd
    # Start just io-pkt here if you aren't loading devnp-cpsw2g.so when booting
    # Remove this line if you start io-pkt above and load cpsw2g
    # io-pkt-v6-hc

    # Ensure that TCP/IP am0 interface is available before the script continue
    # if_up -p am0

    # Set IP address
    # dhclient -m -lf /dev/shmem/dhclient.leases -pf /dev/shmem/dhclient.pid -nw am0

    # Set static IP if needed
    #ifconfig am0 192.168.2.210

    #######################################################################
    ## OSPI NAND ETFS spiflash driver without UDMA support and no DTR
    #######################################################################
    display_msg "Starting ETFS Flash QSPI driver..."
    fs-etfs-j7ospi -Dclk=80000000,rdelay=3,dqs_en=0,rclk_en=1 -r65536
    #######################################################################
    ## OSPI NAND ETFS spiflash driver with UDMA and DTR support
    ## need tisci-mgr and tiudma-mgr to access TI UDMA library
    ## need direct mode for DMA transfer
    #######################################################################
    # display_msg "Starting ETFS Flash uDMA QSPI-DTR driver..."
    # fs-etfs-j7ospi -Dclk=80000000,rdelay=3,dqs_en=0,rclk_en=1,poffset=32704,dac=1,phy=1,dma=1,dtr_en=1 -r65536
    #######################################################################
    ## OSPI NAND ETFS spiflash driver with UDMA support and no DTR
    ## need tisci-mgr and tiudma-mgr to access TI UDMA library
    ## need direct mode for DMA transfer
    #######################################################################
    # display_msg "Starting ETFS Flash uDMA QSPI driver..."
    # fs-etfs-j7ospi -Dclk=80000000,rdelay=3,dqs_en=0,rclk_en=1,poffset=32704,dac=1,phy=1,dma=1 -r65536


    # Start the main shell
    # [+session] ksh /proc/boot/.console.sh &
    [+session] ksh /proc/boot/.console_ti.sh &

}

[type=link] /bin/sh=ksh

# Redirect console messages
[type=link] /dev/console=/dev/ser1

[type=link] /tmp=/dev/shmem
[type=link] /var/log=/tmp
[type=link] /usr/tmp=/tmp

# Programs require the runtime linker (ldqnx.so) to be at a fixed location
/usr/lib/ldqnx-64.so.2=ldqnx-64.so.2

# Shared libraries
/lib/libc.so=libc.so
/lib/libgcc_s.so.1=libgcc_s.so.1
/lib/libregex.so=libregex.so
/lib/libqh.so=libqh.so
/lib/libm.so=libm.so

