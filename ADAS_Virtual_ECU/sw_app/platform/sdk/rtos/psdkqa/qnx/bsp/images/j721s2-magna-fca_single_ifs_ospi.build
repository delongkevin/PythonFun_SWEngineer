###########################################################################
## Set environment and start the main shell
###########################################################################
[perms=0755] .console.sh={
    echo setting env variables.

    export SYSNAME=nto
    export TERM=qansi
    export HOME=/
    export PS1='FCA_DT@QNX:$(pwd)# '
    export PATH=/proc/boot:/bin:/usr/bin:/sbin:/usr/sbin:/usr/lib
    #GRAPHICS_ROOT=/ti_fs/usr/lib/graphics/j721s2
    #export LD_LIBRARY_PATH=/proc/boot:/lib:/usr/lib:/lib/dll:/lib/dll/pci:$GRAPHICS_ROOT
    #export LD_LIBRARY_PATH=/proc/boot:/lib:/usr/lib:/lib/dll:/lib/dll/pci:/ti_fs/usr/lib:/ti_fs/lib:/ti_fs/vision_apps:/ti_fs/bin/:$GRAPHICS_ROOT
    waitfor /dev/screen

    #echo Mounting ETFS ..
    touch /tmp/etfs_status
    echo "1" > /tmp/etfs_status

    waitfor /dev/etfs2 5 
    mount -t etfs /dev/etfs2 /fs
    waitfor /fs 5
    if [ -e /fs/.filetable ]; then
        mkdir -p /fs/variants
        waitfor fs/variants 5
    if test $? -ne 0; then
            echo "fs/variants folder create failed!"
            echo "0" > /tmp/etfs_status
        fi 
    else
       	echo "NAND partition doesn't exist!! Format NAND flash!"
        #restart the driver
        slay fs-etfs-j7ospi
        fs-etfs-j7ospi -v -Drclk=200000000,clk=50000000,rdelay=2,dqs_en=0,rclk_en=0,dma=1,dac=1,verbose=2 -r111104
        waitfor /dev/etfs2 5
        etfsctl -d /dev/etfs2 -f
        if test $? -ne 0; then
            echo "0" > /tmp/etfs_status
            echo "Flash Format Failed!"
        else
            mount -t etfs /dev/etfs2 /fs
            waitfor /fs 5
            if [ -e /fs/.filetable ]; then                                   
                mkdir -p /fs/variants 
                waitfor fs/variants 5
                if test $? -ne 0; then
                    echo "0" > /tmp/etfs_status
                    echo "fs/variants folder create failed..!"
                fi
            else
                echo "0" > /tmp/etfs_status
                echo "etfs mount failed!"
            fi
        fi   
	fi    
exec ksh -l
}

###########################################################################
## Set environment and start the main shell
###########################################################################
[perms=0744] .console_ti.sh={
        # These environment variables are inherited by all the programs that follow.
        echo Setting environment variables...
        export SYSNAME=nto
        export TERM=qansi
        export HOME=/
        export PS1="J721S2-FCA# "
        export PATH=/proc/boot:/bin:/usr/bin:/sbin:/usr/sbin:/usr/lib
        export LD_LIBRARY_PATH=/proc/boot:/lib:/usr/lib:/lib/dll:/lib/dll/pci
        #######################################################################
        ## vision_apps environment variables
        #######################################################################
        # Location of the input data for vision apps demos
        export VX_TEST_DATA_PATH=/ti_fs/vision_apps/test_data
        # Location of the input data for PTK demos
        export TIAP_DATABASE_PATH=/ti_fs/vision_apps/test_data_ptk
        # Location of the input data for Stereo demo
        export APP_STEREO_DATA_PATH=$VX_TEST_DATA_PATH/psdkra/stereo_test_data
        # APP config path for PTK demos
        export APP_CONFIG_BASE_PATH=/ti_fs/vision_apps/ptk_app_cfg
        echo done..
        #######################################################################
        ## Run user script if it exists
        #######################################################################
        echo Mounting the sd ..
        waitfor /dev/sd0 10
        mount -tdos -oexe=all /dev/sd0t12 /ti_fs
        echo Looking for user script to run: /ti_fs/scripts/user.sh
        /proc/boot/waitfor  /ti_fs/scripts/user.sh
        user_script=/ti_fs/scripts/user.sh
        if [ -e "$user_script" ]; then
                echo Running user script...
                . "$user_script"
        fi
        echo done...
        ksh -l
}

#######################################################################
## REMOTE_DEBUG (gdb or Momentics)
##  - refer to the help documentation for the gdb, qconn and the IDE
##    for more information on remote debugging
##  - the commands shown require that NETWORK is enabled too
#######################################################################
[perms=0755] /usr/ethernet.sh = {
    echo "Starting network..."
   io-pkt-v6-hc -d cpsw2g
   sleep 1
   if_up -p am0
   sleep 1
   ifconfig am0 192.168.2.210
   sleep 1

   echo "CPSW2G... Static IP 192.168.2.210"
   echo "enabling qconn"
   qconn
   echo "starting qconn.."
   sleep 1
   devc-pty
   inetd
}

#######################################################################
## Watchdog Script for PUC App restart 
#######################################################################
[perms=0755] /usr/watchdog.sh = {
    COMP="0xABCD"
    echo $COMP

    input="/tmp/ISTREAMON.txt"
    while IFS= read -r line
    do
        echo "$line"
    done < "$input"

    STREAMON=$line
    echo $STREAMON
    echo "read data from ISTREAMON.txt"

    while [ 1 ]; do
        sleep 6
        echo "compare STREAMON with COMP"
        echo $STREAMON
        echo $COMP
        if [[ $STREAMON == $COMP ]]
        then
            echo $COMP
            echo $STREAMON
            echo "match"
            sleep 3000
        else
            echo $STREAMON
            echo $COMP
            echo "No match"
            rm -rf /tmp/puc_app.out.core
            slay puc_app.out
            puc_app.out&
        fi
    done
}

# Create a profile so telnet sessions will get environment variables
/etc/profile={
export HOME=/
export SYSNAME=nto
export TERM=qansi
}

