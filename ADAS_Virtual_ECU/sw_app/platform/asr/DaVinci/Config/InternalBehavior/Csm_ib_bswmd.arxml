                        </BSW-SCHEDULABLE-ENTITY>
                      </ENTITYS>
                      <EVENTS>
                        <BSW-TIMING-EVENT UUID="c8cad416-dacd-4731-9cdd-7d3b7ebc17f7">
                          <SHORT-NAME>Csm_MainFunctionTimingEvent0</SHORT-NAME>
