                    <COMPU-METHOD UUID="acde8e79-339c-4ca2-8463-088874487a3b">
                      <SHORT-NAME>WdgM_GlobalStatusType</SHORT-NAME>
                      <CATEGORY>TEXTTABLE</CATEGORY>
                      <COMPU-INTERNAL-TO-PHYS>
                        <COMPU-SCALES>
                          <COMPU-SCALE>
                            <SHORT-LABEL>WDGM_GLOBAL_STATUS_OK</SHORT-LABEL>
