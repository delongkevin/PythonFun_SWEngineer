                                  <VALUE>ComM_StateType CN_FDCAN2_28a8fc44 = COMM_NO_COM_NO_PENDING_REQUEST;&#13;
&#13;
&#13;
(void)ComM_GetState(ComMConf_ComMChannel_CN_FDCAN2_28a8fc44, &amp;CN_FDCAN2_28a8fc44); /* SBSW_BSWM_FCTCALL_LOCALVAR */&#13;
