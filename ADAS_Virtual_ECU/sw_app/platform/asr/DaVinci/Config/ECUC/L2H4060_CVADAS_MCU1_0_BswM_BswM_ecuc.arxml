                      <REFERENCE-VALUES>
                        <ECUC-REFERENCE-VALUE>
                          <DEFINITION-REF DEST="ECUC-FOREIGN-REFERENCE-DEF">/MICROSAR/BswM/BswMConfig/BswMModeControl/BswMSwitchPort/BswMModeSwitchInterfaceRef</DEFINITION-REF>
                          <VALUE-REF DEST="MODE-SWITCH-INTERFACE">/PortInterfaces/IF_SSM_SystemState</VALUE-REF>
