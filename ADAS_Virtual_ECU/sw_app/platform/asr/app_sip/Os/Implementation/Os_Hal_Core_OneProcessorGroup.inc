/***********************************************************************************************************************
 *  Os_Hal_CoreGetId_Asm()
 **********************************************************************************************************************/
/*! \brief        Returns the physical core ID in the register r0
 *  \details      Valid for derivatives having only one processor group
 *                Invoked in exception handlers.
 *  \param[in]    lr : link register holding the return address
 *  \param[out]   Register r0 holding the core ID
 *  \context      OS_INTERNAL
 *  \reentrant    FALSE
 *  \synchronous  TRUE
 *  \pre          -
 **********************************************************************************************************************/
OS_HAL_ASM_FUNCTION_BEGIN(Os_Hal_CoreGetId_Asm)
  mrc    p15,#0,r0,c0,c0,#5             /* R0 = MPIDR */
  and    r0, r0, #0xFF                  /* R0 keeps the processor identifier field */
  bx     lr
  OS_HAL_ASM_FUNCTION_END(Os_Hal_CoreGetId_Asm)

