/***********************************************************************************************************************
 *  Os_Hal_CoreGetId_Asm
 **********************************************************************************************************************/
/*! \brief        Returns the core ID in the register r0
 *  \details      Invoked in exception handlers.
 *                r1 is modified by this macro.
 *  \param[in]    lr : link register holding the return address
 *  \param[out]   Register r0 holding the core ID
 *  \context      OS_INTERNAL
 *  \reentrant    FALSE
 *  \synchronous  TRUE
 *  \pre          -
 **********************************************************************************************************************/
OS_HAL_ASM_FUNCTION_BEGIN(Os_Hal_CoreGetId_Asm)
  mrc    p15,#0,r0,c0,c0,#5             /* R0 = MPIDR */                                   
  and    r1, r0, #0x01                  /* R1 keeps the processor identifier field */      
  and    r0, r0, #0xFF00                /* R0 keeps the GroupId field */                   
  lsr    r0, r0, #0x7                   /* R0 = GroupId field shifted by 7 to the right */ 
  orr    r0, r0, r1                     /* R0 = Core Id */
  bx     lr
  OS_HAL_ASM_FUNCTION_END(Os_Hal_CoreGetId_Asm)


