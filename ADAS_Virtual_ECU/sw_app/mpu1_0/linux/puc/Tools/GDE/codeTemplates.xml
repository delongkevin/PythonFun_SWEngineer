<?xml version="1.0" encoding="UTF-8"?>
<CodeTemplates>
	<General>
		<!-- 	specifies the tabulator
				use space or &#x9; for the tabulator Control character
				only the first character is used
				if &#x9; is used width should be set to 1
		-->
		<Tabulator character=" " width="2" />
		
		<!-- 	specifies the end of line
				possible values are:
					windows
					linux
					mac
		-->
		<LineEnd type="windows" />
		
		<!-- 	specifies the comment style
				possible values are:
					C ..... for C-style
					C++ ... for C++ style
		-->
		<CommentStyle>C++</CommentStyle>

		<!--	generated code will be inside this namespace -->
		<Namespace name="variants" />
		
		<!-- 	these regular expressions are used to verify the user input for the names of
					* Enumeration
					* EnumElement
					* Component
					* Generic Datatypes (int, float, ...)
					* Asset
		-->
		<InputValidation>
			<Enumeration validator="[A-Z]([A-Z0-9]*[a-z][a-z0-9]*|[a-z0-9]*[A-Z][A-Z0-9]*)[A-Za-z0-9]*" />
			<EnumElement validator="[A-z]([A-Z0-9]*[a-z][a-z0-9]*|[a-z0-9]*[A-Z][A-Z0-9]*)[A-Za-z0-9]*" />
			<Component validator="[A-Z]([A-Z0-9]*[a-z][a-z0-9]*|[a-z0-9]*[A-Z][A-Z0-9]*)[A-Za-z0-9]*" />
			<GenericData validator="[a-z]([A-Z0-9]*[a-z][a-z0-9]*|[a-z0-9]*[A-Z][A-Z0-9]*)[A-Za-z0-9]*" />
			<Asset validator="[A-Z]([A-Z0-9]*[a-z][a-z0-9]*|[a-z0-9]*[A-Z][A-Z0-9]*)[A-Za-z0-9]*" />
		</InputValidation>
	</General>
	<HeaderFile>
		<!--	The comment block for the comment block at the top of the generated files.
				Various placeholders can be used:
					FileName ........ filename without file-extension
					FileNameUpper ... uppercase filename without file-extension
					DateTime ........ date and time of generation
					UserName ........ windows username of the account used to generate the file
		-->
		<HeaderComment>
<![CDATA[/* PRQA S 1011 EOF */ /* C99 comments allowed, this file is shared between cpp and c */
/* PRQA S 3077 EOF */ /* downcast is intended here */
/// @file ]]><FileName /><![CDATA[
/// @brief Contains the ]]><FileName /><![CDATA[ implementation.
/// This file is generated by the Generic Data Editor. Do not change manually!
/// Generated on: ]]><DateTime />
<![CDATA[///
/// --------------------------------------------------------------------------
/// @copyright MAGNA Electronics - C O N F I D E N T I A L <br>
/// This document in its entirety is CONFIDENTIAL and may not be disclosed,
/// disseminated or distributed to parties outside MAGNA Electronics
/// without written permission from MAGNA Electronics.
///
/// @author ]]><UserName />
		</HeaderComment>
		<!-- 	configures the name for the include guard 
				will be concatenated for the final name
				<FileNameUpper /> will be replaced by the uppercase-name of the file
		-->
		<IncludeGuard>VARIANTS_<FileNameUpper />_H</IncludeGuard>
	</HeaderFile>
	<!--	Add files to be included here.
			Possible sections are:
				<Enums>
				<Components>
				<Assets>
				<AssetManager>
			Inside these sections there can be multiple Tags like:
				<Include filePath="pathTo/file.h" />
	-->
	<ExtraIncludes>
		<Components>
			<Include filePath="platform/PlatformAPI.h" />
			<Include filePath="osal/io/InOut.h" />
		</Components>
		<AssetManager>
			<Include filePath="platform/PlatformAPI.h" />
			<Include filePath="osal/io/InOut.h" />
		</AssetManager>
	</ExtraIncludes>
</CodeTemplates>