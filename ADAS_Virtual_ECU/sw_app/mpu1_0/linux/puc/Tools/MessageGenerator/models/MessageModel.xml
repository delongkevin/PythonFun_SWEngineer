<?xml version="1.0" encoding="UTF-8"?>

<Configuration>
	<AdditionalIncludes>
		<Include Text="MessageSerializer.h"/>
	</AdditionalIncludes>
</Configuration>

<Messages>
	<Message ID ="20" Name="BootState">
		<DataType Type="sint32_t" Name="bootState_s32" Comment="enum aZynqM_E_ModuleState_e"/>
	</Message>
	
	<Message ID ="30" Name="RequestApplyConfig">
		<DataType Type="sint32_t" Name="languageID" Comment="ME_Hydra2defs_E_Language_e"/>
		<DataType Type="sint32_t" Name="vehicleConfigID" Comment="Supported Vehicle Configuration"/>
		<DataType Type="sint32_t" Name="frameRate" Comment="25 or 30"/>
		<DataType Type="sint32_t" Name="flickerFrequency" Comment="50 Hz or 60 Hz"/>
		<DataType Type="uint8_t"  Name="digitalOutput" Comment="0=Analog, 1=Digital (displayConfig struct)"/>
		<DataType Type="sint32_t" Name="outputResolution" Comment="output Resolution Enum (displayConfig struct)"/>
		<DataType Type="uint8_t"  Name="failSafe" Comment="Failsafe (ME_Hydra2defs_S_ConfigBits_s struct)"/>
		<DataType Type="uint8_t"  Name="debugFacilities" Comment="0=OFF, 1=ON (ME_Hydra2defs_S_ConfigBits_s struct)"/>
		<DataType Type="uint8_t"  Name="driverPosition" Comment="0=left hand drive, 1=right hand drive (ME_Hydra2defs_S_ConfigBits_s struct)"/>
		<DataType Type="uint8_t"  Name="configuredCams" Comment="ME_HYDRA2DEFS_D_FRONTCAM 0x01 ME_HYDRA2DEFS_D_LEFTCAM 0x02 ME_HYDRA2DEFS_D_REARCAM 0x04 ME_HYDRA2DEFS_D_RIGHTCAM 0x08 ME_HYDRA2DEFS_D_5THCAM 0x10"/>
	</Message>

	<Message ID ="110" Name="RequestScreen">
		<DataType Type="sint32_t" Name="Version"   Comment="Version Identifier"/>
		<DataType Type="sint32_t" Name ="ViewID"   Comment="View Identifier"/>
		<DataType Type="uint8_t"  Name="ZoomFactor" Comment="Zoom Factor"/>
		<DataType Type="uint8_t"  Name="Overlays"  ArrayLength="32" ArraySizeName="c_MaxOverlays_u32" Comment="Overlay Bits Array"/>
	</Message>
	
	<Message ID ="120" Name="SendVehicleState">
		<DataType Type="float32_t" Name="VehicleLevel"/>
		<DataType Type="float32_t" Name="SteeringAngle"/>
	</Message>
	
	<Message ID ="440" Name="TestAllDataTypes">
		<DataType Type="uint8_t"   Name="Test"/>
		<DataType Type="uint16_t"  Name="Test"/>
		<DataType Type="uint32_t"  Name="Test"/>
		<DataType Type="uint64_t"  Name="Test"/>
		<DataType Type="sint8_t"   Name="Test"/>
		<DataType Type="sint16_t"  Name="Test"/>
		<DataType Type="sint32_t"  Name="Test"/>
		<DataType Type="sint64_t"  Name="Test"/>
		<DataType Type="float32_t" Name="Test"/>
	</Message>

</Messages>