    o_classProb_f32 = 0.0f;
    uint32_t v_classID = 0;
    std::vector<float32_t> inputVector = preprocessImageONNX( trailerROIImg );
    // create inputs tensors and initialize output tensors
    Ort::Value inputTensor = Ort::Value::CreateTensor<float32_t>(
                                 Ort::MemoryInfo::CreateCpu( OrtArenaAllocator, OrtMemTypeDefault ),
                                 inputVector.data(),
                                 inputVector.size(),
                                 m_inputNodeDims.data(),
                                 m_inputNodeDims.size()
                             );
    std::vector<Ort::Value> outputTensors;
    outputTensors = m_Ortsession->Run(
                        Ort::RunOptions{ nullptr },
                        inputTensorNames.data(),
                        &inputTensor,
                        inputTensorNames.size(),
                        outputTensorNames.data(),
                        outputTensorNames.size()
                    );
    // process results
    int64_t maxCandidates = m_outputNodeDims[0][1];
    float32_t* predScore = outputTensors.at( 0 ).GetTensorMutableData<float>();
#ifndef OD_ONNX_POSE_SOFTMAX
    softmax( predScore, maxCandidates );
#endif // OD_ONNX_POSE_SOFTMAX

    for( size_t i = 0; i < maxCandidates; i++ )
    {
        if( predScore[i] > o_classProb_f32 )
        {
            o_classProb_f32 = predScore[i];
            v_classID = i;
        }
    }

    return v_classID;
}

void COdOnnx::MaxSupression()
{
    int32_t box_cnt = detCount;
    //int32_t class_iou_ind;
    bool_t FoundOne = true;
    bool_t Flags[MAX_DETECTIONS] = { false };

    while( FoundOne )
    {
        int32_t ind = 0;
        float32_t Smax = 0;
        FoundOne = false;

        for( size_t i = 0; i < box_cnt; i++ )
        {
            if( Flags[i] )
            {
                continue;
            }

            if( m_det[i].prob > Smax )//PRQA S 3706
            {
                Smax = m_det[i].prob;//PRQA S 3706
                ind = i;
                FoundOne = true;
            }
        }

        if( FoundOne )
        {
            BBBox_t DBox = m_det[ind].m_box;//PRQA S 3706
            int32_t DClass = m_det[ind].ClassID;//PRQA S 3706
            m_det[ind].validFlag = true;//PRQA S 3706
            Flags[ind] = true;
            float32_t box1_area = static_cast<float32_t>( ( DBox.right - DBox.left ) * ( DBox.bottom - DBox.top ) );

            for( size_t i = 0; i < box_cnt; i++ )
            {
                if( Flags[i] )
                {
                    continue;
                }

                if( m_det[i].ClassID == DClass )//PRQA S 3706
                {
                    float32_t box2_area = ( float32_t )( m_det[i].m_box.right - m_det[i].m_box.left ) * ( m_det[i].m_box.bottom - m_det[i].m_box.top );//PRQA S 3706
                    float32_t box_intersection = ( float32_t )( mecl::math::min_x( m_det[i].m_box.right, DBox.right ) - mecl::math::max_x( m_det[i].m_box.left, DBox.left ) ) *
                                                 ( mecl::math::min_x( m_det[i].m_box.bottom, DBox.bottom ) - mecl::math::max_x( m_det[i].m_box.top, DBox.top ) );//PRQA S 3706

                    if( ( m_det[i].m_box.left > DBox.right ) || ( DBox.left > m_det[i].m_box.right ) || ( m_det[i].m_box.top > DBox.bottom ) || ( DBox.top > m_det[i].m_box.bottom ) )
                    {
                        box_intersection = 0;
                    }

                    float32_t iou = box_intersection / ( box1_area + box2_area - box_intersection );
                    // if using Coco map, class specific parameters not implemented; default to pedestrian IOU threshold
                    //class_iou_ind = ( labelType == 1 ) ? 1 : DClass;

                    if( iou > 0.5f )
                    {
                        m_det[i].validFlag = false;//PRQA S 3706
                        Flags[i] = true;
                    }
                }
            }
        }
    }
}

void COdOnnx::BoxPredictionProcess( float32_t* pred_boxes, uint32_t totalDetection, uint32_t detSize )
{
    //int32_t detSize = 7; // detSize = 7 (for 2 class), 8 (for 3 class)
    //int32_t class_conf_ind;
    // COCO: 80 classes
    //else if (labelType == 2) detSize = 7; // Magna: 5 classes
    for( size_t i = 0; i < totalDetection; i++ )
    {
        int32_t class_ind = 0;
        float32_t detection_scores = 0;

        for( size_t j = 5; j < detSize; j++ )
            if( pred_boxes[i * detSize + j] > detection_scores )//PRQA S 3706
            {
                detection_scores = pred_boxes[i * detSize + j];//PRQA S 3706
                class_ind = j - 4;
            }

        detection_scores *= pred_boxes[i * detSize + 4];//PRQA S 3706
        // if using Coco map, class specific confidences not implemented; default to pedestrian confidence
        //class_conf_ind = ( labelType == 1 ) ? 1 : class_ind;

        //if( ( detection_scores >= m_objectClassParams[class_conf_ind].confidenceThresh ) && ( detCount < MAX_DETECTIONS ) )
        if( ( detection_scores >= 0.5f ) && ( detCount < MAX_DETECTIONS ) )
        {
            m_det[detCount].ClassID = class_ind;//PRQA S 3706
            m_det[detCount].prob = detection_scores;//PRQA S 3706
            m_det[detCount].m_box.left = static_cast<int32_t>( pred_boxes[i * detSize] - 0.5 * pred_boxes[i * detSize + 2] ); //PRQA S 3706
            m_det[detCount].m_box.top = static_cast<int32_t>( pred_boxes[i * detSize + 1] - 0.5 * pred_boxes[i * detSize + 3] );//PRQA S 3706
            m_det[detCount].m_box.right = static_cast<int32_t>( pred_boxes[i * detSize] + 0.5 * pred_boxes[i * detSize + 2] );//PRQA S 3706
            m_det[detCount].m_box.bottom = static_cast<int32_t>( pred_boxes[i * detSize + 1] + 0.5 * pred_boxes[i * detSize + 3] );//PRQA S 3706
            m_det[detCount].validFlag = true;//PRQA S 3706
            detCount++;
        }
    }
}

void COdOnnx::BoxPredictionProcessNms( float32_t* pred_boxes, uint32_t totalDetection, uint32_t detSize )
{
    for( size_t i = 0; i < totalDetection; i++ )
    {
        float32_t detection_scores = pred_boxes[i * detSize + 4];//PRQA S 3706

        if( ( detection_scores >= 0.5f ) && ( detCount < MAX_DETECTIONS ) )
        {
            m_det[detCount].ClassID = pred_boxes[i * detSize + 5] + 1;//PRQA S 3706
            m_det[detCount].prob = detection_scores;//PRQA S 3706
            m_det[detCount].m_box.left      = static_cast<int32_t>( pred_boxes[i * detSize + 0] ); //PRQA S 3706
            m_det[detCount].m_box.top       = static_cast<int32_t>( pred_boxes[i * detSize + 1] ); //PRQA S 3706
            m_det[detCount].m_box.right     = static_cast<int32_t>( pred_boxes[i * detSize + 2] ); //PRQA S 3706
            m_det[detCount].m_box.bottom    = static_cast<int32_t>( pred_boxes[i * detSize + 3] ); //PRQA S 3706
            m_det[detCount].validFlag = true;//PRQA S 3706
            detCount++;
        }
    }
}

void COdOnnx::softmax( float32_t* o_pScores_f32, const uint32_t& i_cntScores_u32 )
{
    size_t i;
    float32_t m, sum, constant;
    m = -INFINITY;

    for( i = 0; i < i_cntScores_u32; ++i )
    {
        if( m < o_pScores_f32[i] )
        {
            m = o_pScores_f32[i];
        }
    }

    sum = 0.0;

    for( i = 0; i < i_cntScores_u32; ++i )
    {
        sum += exp( o_pScores_f32[i] - m );
    }

    constant = m + log( sum );

    for( i = 0; i < i_cntScores_u32; ++i )
    {
        o_pScores_f32[i] = exp( o_pScores_f32[i] - constant );
    }
}


std::wstring COdOnnx::to_wstring( std::string const& str )
{
    size_t len = mbstowcs( nullptr, &str[0], 0 );
    std::wstring wstr( len, 0 );
    mbstowcs( &wstr[0], &str[0], wstr.size() );
    return wstr;
}

/*
* Functions to validate and correct bounding box w.r.t. image size
*/
bool_t COdOnnx::ValidateAndUpdateBB( Recti& io_BB, int32_t i_imgW, int32_t i_imgH )
{
    bool_t v_ValidBB_b = false;
    io_BB.x = ( io_BB.x < 0 ) ? 0 : io_BB.x;
    io_BB.y = ( io_BB.y < 0 ) ? 0 : io_BB.y;
    io_BB.x = ( io_BB.x < i_imgW ) ? io_BB.x : ( i_imgW - 1 );
    io_BB.y = ( io_BB.y < i_imgH ) ? ( io_BB.y ) : ( i_imgH - 1 );
    io_BB.width = ( ( io_BB.x + io_BB.width ) < i_imgW ) ?
                  io_BB.width :
                  ( io_BB.width - ( ( io_BB.x + io_BB.width ) - i_imgW ) );
    io_BB.height = ( ( io_BB.y + io_BB.height ) < i_imgH ) ?
                   io_BB.height :
                   ( io_BB.height - ( ( io_BB.y + io_BB.height ) - i_imgH ) );

    if( io_BB.width < 2 || io_BB.height < 2 )
    {
        v_ValidBB_b = false;
    }
    else
    {
        v_ValidBB_b = true;
    }

    return v_ValidBB_b;
}