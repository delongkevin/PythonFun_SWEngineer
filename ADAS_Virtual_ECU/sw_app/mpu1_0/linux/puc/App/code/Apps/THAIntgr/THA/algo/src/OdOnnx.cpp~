                    m_Result.pushBack_v( objInfo );
                }

                break;
            }

            // --- Coupler region
            case 4:
            {
                objInfo.Type = ODType::Obj_CouplerReg;

                if( m_EnableODONNXCrop == true )
                {
                    objInfo.Rect.x = objInfo.Rect.x + v_rectStartX;
                    objInfo.Rect.y = objInfo.Rect.y + v_rectStartY;
                }

                /* Update rectangle */
                if( ValidateAndUpdateBB( objInfo.Rect, i_ImgWidth_u16, i_ImgHeight_u16 ) )
                {
                    objInfo.Point_2D = Point2i( objInfo.Rect.x + ( 0.5f * objInfo.Rect.width ), objInfo.Rect.y + ( 0.5f * objInfo.Rect.height ) );
                    m_Result.pushBack_v( objInfo );
                }

                break;
            }

            default:
            {
                break;
            }
        }

#if WINDOWS_IMG_DET_DUMP
        cv::rectangle( inputImgDump, cv::Rect( objInfo.Rect.x, objInfo.Rect.y, objInfo.Rect.width, objInfo.Rect.height ), cv::Scalar( 0, 255, 255 ) );
#endif // WINDOWS_IMG_DET_DUMP      
    }

    v_ObjDetCnt = m_Result.size_u32();
    return v_ObjDetCnt;
}

