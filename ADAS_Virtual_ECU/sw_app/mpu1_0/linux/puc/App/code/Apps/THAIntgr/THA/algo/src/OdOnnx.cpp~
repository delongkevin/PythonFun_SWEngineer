                {
                    objInfo.Point_2D = Point2i( objInfo.Rect.x + ( 0.5f * objInfo.Rect.width ), objInfo.Rect.y + ( 0.5f * objInfo.Rect.height ) );
                    m_Result.pushBack_v( objInfo );
                }

                break;
            }

            // --- Hitch ball
            case 3:
            {
                objInfo.Type = ODType::Obj_Hitch;

                if( m_EnableODONNXCrop == true )
                {
                    objInfo.Rect.x = objInfo.Rect.x + v_rectStartX;
                    objInfo.Rect.y = objInfo.Rect.y + v_rectStartY;
