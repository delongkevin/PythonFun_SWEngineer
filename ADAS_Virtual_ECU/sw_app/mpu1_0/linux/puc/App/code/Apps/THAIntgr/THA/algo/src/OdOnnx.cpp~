void COdOnnx::Reinit( Ort::Env* i_environment, const std::string modelPath )
{
    /*
    * load onnx file
    */
    std::wstring wModelPath = to_wstring( modelPath.c_str() );

    if( m_Ortsession != NULL )
    {
        m_Ortsession = new Ort::Session( *i_environment, wModelPath.c_str(), *m_Ortsession_options );
        inputTensorNames.clear();
        outputTensorNames.clear();
    }

    size_t num_input_nodes = m_Ortsession->GetInputCount();
    inputTensorNames.reserve( num_input_nodes );

    /*
    * input and output tensor dimensions
    */
    for( size_t i = 0; i < m_Ortsession->GetInputCount(); i++ )
    {
        char_t* input_name = m_Ortsession->GetInputName( i, *m_Ortallocator );
        inputTensorNames.push_back( input_name );
        Ort::TypeInfo type_info = m_Ortsession->GetInputTypeInfo( i );
        auto tensor_info = type_info.GetTensorTypeAndShapeInfo();
        m_inputNodeDims = tensor_info.GetShape();
    }

    for( size_t i = 0; i < m_Ortsession->GetOutputCount(); i++ )
    {
        char_t* output_name = m_Ortsession->GetOutputName( i, *m_Ortallocator );
        outputTensorNames.push_back( output_name );
        Ort::TypeInfo type_info = m_Ortsession->GetOutputTypeInfo( i );
        auto tensor_info = type_info.GetTensorTypeAndShapeInfo();
        m_outputNodeDims.push_back( tensor_info.GetShape() );
    }

    m_inputNodeChannel = m_inputNodeDims[1];
    m_inputNodeHeight = m_inputNodeDims[2];
    m_inputNodeWidth = m_inputNodeDims[3];
}
#endif // ENABLE_MULTI_DET_DNN

void COdOnnx::Release()
{
    for( const char_t* node_name : inputTensorNames )
    {
        m_Ortallocator->Free( const_cast<void*>( reinterpret_cast<const void*>( node_name ) ) );
    }

    if( m_Ortsession != NULL )
    {
        m_Ortsession->release();
    }

    if( m_Ortsession_options != NULL )
    {
        m_Ortsession_options->release();
    }

    if( m_Ortallocator != NULL )
    {
        delete m_Ortallocator;
        m_Ortallocator = NULL;
    }

    if( classList.size() > 0 )
    {
        std::vector<std::string>().swap( classList );
    }

    if( inputTensorNames.size() > 0 )
    {
        std::vector<const char_t*>().swap( inputTensorNames );
    }

    if( outputTensorNames.size() > 0 )
    {
        std::vector<const char_t*>().swap( outputTensorNames );
    }

    if( m_inputNodeDims.size() > 0 )
    {
        std::vector<int64_t>().swap( m_inputNodeDims );
    }

    if( m_outputNodeDims.size() > 0 )
    {
        for( size_t i = 0; i < m_outputNodeDims.size(); i++ )
        {
            std::vector<int64_t>().swap( m_outputNodeDims[i] );
        }

        m_outputNodeDims.clear();
        m_outputNodeDims.shrink_to_fit();
    }

    if( m_Result.size_u32() > 0 )
    {
        m_Result.clear_v();
    }

    if( m_det != NULL )
    {
        delete[] m_det;
    }
}
std::vector<float32_t> COdOnnx::preprocessImageONNX( cv::Mat image )
{
    cv::Mat pixels;
    cv::Mat imageResize;
    cv::resize( image, imageResize, cv::Size( m_inputNodeWidth, m_inputNodeHeight ), 0, 0, cv::INTER_LINEAR );
#ifdef DNN_IN_IMG_WRITE
    // Use below 3 variables to decide what image
    // type and resolution needs to be dumped
    bool genRGB = true;
    bool genGray = true;
    bool resizeTo640x400 = true;
    //
    static int aa = 0;
    uint8_t* buffer = NULL;
    uint8_t* grayBuf = NULL;
    uint32_t bufsize;
    uint32_t image_offset;
    uint16_t inNodeHeight = m_inputNodeHeight;
    uint16_t inNodeWidth = m_inputNodeWidth;
    //if( aa == 0 )
    //{
    cv::Mat resizedMat;

    if( resizeTo640x400 )
    {
        inNodeHeight = 400;
        inNodeWidth = 640;
    }

    bufsize = ( inNodeWidth * inNodeHeight * 3 );
    image_offset = inNodeWidth * inNodeHeight;
    buffer = ( uint8_t* )malloc( bufsize );
    grayBuf = ( uint8_t* )malloc( image_offset );
    cv::resize( image, resizedMat, cv::Size( inNodeWidth, inNodeHeight ), 0, 0, cv::INTER_LINEAR );
    uint64_t k = 0;
    uint32_t bytesW;
    cv::Vec3b bgrPixel;

    if( genRGB )
    {
        k = 0;

        for( uint16_t i = 0; i < inNodeHeight; i++ )
        {
            for( uint16_t j = 0; j < inNodeWidth; j++ )
            {
                bgrPixel = resizedMat.at<cv::Vec3b>( i, j );
                // Adding BGR pixel values to RGB planes using offset of each plane
                buffer[k] = bgrPixel[2];
                buffer[image_offset + k] = bgrPixel[1];
                buffer[( image_offset * 2 ) + k] = bgrPixel[0];
                k++;
            }
        }

        std::string fileNameRGB = "THA/dnn_in_img_rgb_planar" + std::to_string( aa ) + ".bin";
        //FILE* f = fopen( "THA/dnn_in_img_rgb_planar.bin", "wb" );
        FILE* f = fopen( fileNameRGB.c_str(), "wb" );
        bytesW = fwrite( buffer, 1, bufsize, f );
        fclose( f );
    }

    if( genGray )
    {
        k = 0;

        for( uint16_t i = 0; i < inNodeHeight; i++ )
        {
            for( uint16_t j = 0; j < inNodeWidth; j++ )
            {
                bgrPixel = resizedMat.at<cv::Vec3b>( i, j );
                // Converting RGB to grayscale using [ grayscale = ((0.3 * R) + (0.59 * G) + (0.11 * B)) ]
                grayBuf[k] = ( ( 0.3 * bgrPixel[2] ) + ( 0.59 * bgrPixel[1] ) + ( 0.11 * bgrPixel[0] ) );
                k++;
            }
        }

        std::string fileNameGray = "THA/dnn_in_img_grayscale" + std::to_string( aa ) + ".bin";
        FILE* fg = fopen( fileNameGray.c_str(), "wb" );
        bytesW = fwrite( grayBuf, 1, image_offset, fg );
        fclose( fg );
    }

    aa = aa + 1;
    //    aa = 1;
    //}
#endif
    imageResize.convertTo( pixels, CV_32FC3, 1.0 / 255, 0 );
    //float32_t* pixel_data = ( float32_t* )pixels.datastart;
    float32_t* pixel_data = ( float32_t* )pixels.data;
    std::vector<float32_t> data( m_inputNodeChannel * m_inputNodeHeight * m_inputNodeWidth, 0.0f );

    for( size_t c = 0; c < m_inputNodeChannel; c++ )
        for( size_t j = 0, hw = m_inputNodeWidth * m_inputNodeHeight; j < hw; j++ )
        {
            data[c * hw + j] = pixel_data[m_inputNodeChannel * j + 2 - c];//PRQA S 3706
        }

    return data;
}

