void COdOnnx::Init( Ort::Env* i_environment, const std::string modelPath )
{
    /*
    * session options
    */
    m_Ortsession_options = new Ort::SessionOptions();
    m_Ortsession_options->SetIntraOpNumThreads( 1 );
    m_Ortsession_options->SetGraphOptimizationLevel( GraphOptimizationLevel::ORT_ENABLE_EXTENDED );

    if( EnableGPU_b == true )
    {
        // using cuda
        OrtCUDAProviderOptions cudaOptions{ 0 };
        m_Ortsession_options->AppendExecutionProvider_CUDA( cudaOptions );
    }

    /*
    * load onnx file and create session
    */
    std::wstring wModelPath = to_wstring( modelPath.c_str() );
    m_Ortsession =  new Ort::Session( *i_environment, wModelPath.c_str(), *m_Ortsession_options );
    m_Ortallocator = new Ort::AllocatorWithDefaultOptions;
    size_t num_input_nodes = m_Ortsession->GetInputCount();
    inputTensorNames.reserve( num_input_nodes );

    /*
    * input and output tensor dimenstions
    */
    for( size_t i = 0; i < m_Ortsession->GetInputCount(); i++ )
    {
        char_t* input_name = m_Ortsession->GetInputName( i, *m_Ortallocator );
        inputTensorNames.push_back( input_name );
        Ort::TypeInfo type_info = m_Ortsession->GetInputTypeInfo( i );
        auto tensor_info = type_info.GetTensorTypeAndShapeInfo();
        m_inputNodeDims = tensor_info.GetShape();
    }

    for( size_t i = 0; i < m_Ortsession->GetOutputCount(); i++ )
    {
        char_t* output_name = m_Ortsession->GetOutputName( i, *m_Ortallocator );
        outputTensorNames.push_back( output_name );
        Ort::TypeInfo type_info = m_Ortsession->GetOutputTypeInfo( i );
        auto tensor_info = type_info.GetTensorTypeAndShapeInfo();
        m_outputNodeDims.push_back( tensor_info.GetShape() );
    }

    m_inputNodeChannel = m_inputNodeDims[1];
    m_inputNodeHeight = m_inputNodeDims[2];
    m_inputNodeWidth = m_inputNodeDims[3];
    m_det = new DetectionObject_t[MAX_DETECTIONS];
}
