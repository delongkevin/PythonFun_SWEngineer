    v_SensorCfg64_s.pos1Cfg_x.cVal_ax[1] = static_cast<float64_t>(v_SensorConfig32_s.pos1Cfg_x.cVal_ax[1]);
    v_SensorCfg64_s.pos2Cfg_x.cVal_ax[0] = static_cast<float64_t>(v_SensorConfig32_s.pos2Cfg_x.cVal_ax[0]);
    v_SensorCfg64_s.pos2Cfg_x.cVal_ax[1] = static_cast<float64_t>(v_SensorConfig32_s.pos2Cfg_x.cVal_ax[1]);

    sensor64_o.updateConfig_v(v_SensorCfg64_s);
    camera64_o.setSensor_v(sensor64_o);

    for(uint32_t v_I_u32 = 0U; v_I_u32 < 6U; v_I_u32++)
    {
      v_LensRadialCfg64_s.world2image_x[v_I_u32] = static_cast<float64_t>(v_LensRadialConfig32_s.world2image_x[v_I_u32]);
      v_LensRadialCfg64_s.image2world_x[v_I_u32] = static_cast<float64_t>(v_LensRadialConfig32_s.image2world_x[v_I_u32]);
    }

    v_LensRadialCfg64_s.elevationMaxCfg_x = static_cast<float64_t>(v_LensRadialConfig32_s.elevationMaxCfg_x);

    lensRadial64_o.updateConfig_v(v_LensRadialCfg64_s);
    camera64_o.setLens_v(lensRadial64_o);
  }

  EOL_DEBUG_PRINTF(("extr_ps: %p, Cam_ro: %p\n", c_Extrinsics_ps, &v_Camera_ro));

  if(NULL != c_Extrinsics_ps)
