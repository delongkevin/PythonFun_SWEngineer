    EOL_DEBUG_PRINTF(("p*10K:%d, y*10K:%d, r*10k:%d\n", static_cast<sint32_t>(mecl::math::toDegrees_x(c_Extrinsics_ps->eulerAngles_s.pitch_x*10000.0F)), static_cast<sint32_t>(mecl::math::toDegrees_x(c_Extrinsics_ps->eulerAngles_s.yaw_x*10000.0F)), static_cast<sint32_t>(mecl::math::toDegrees_x(c_Extrinsics_ps->eulerAngles_s.roll_x*10000.0F))));
    EOL_DEBUG_PRINTF(("x*10k:%d, y*10k:%d, z*10k:%d, pre_r:%d, rot_type: %d\n", static_cast<sint32_t>(c_Extrinsics_ps->pos_x.cVal_ax[0]*10000.0F), static_cast<sint32_t>(c_Extrinsics_ps->pos_x.cVal_ax[1]*10000.0F), static_cast<sint32_t>(c_Extrinsics_ps->pos_x.cVal_ax[2]*10000.0F), c_Extrinsics_ps->preRoll_e, c_Extrinsics_ps->rotationType_e));
  }

#ifdef EOL_LOG_PRINTF_ON
  if(NULL != c_EolIntrinsic_ps)
  {
    EOL_DEBUG_PRINTF(("fX*10k:%d,fY*10k:%d,pppCfgX*10k:%d,pppCfgY*10k:%d\n"
        ,static_cast<sint32_t>(c_EolIntrinsic_ps->foclX_x*10000.0F)
        ,static_cast<sint32_t>(c_EolIntrinsic_ps->foclY_x*10000.0F)
        ,static_cast<sint32_t>(c_EolIntrinsic_ps->pppCfg_x.cVal_ax[0]*10000.0F)
        ,static_cast<sint32_t>(c_EolIntrinsic_ps->pppCfg_x.cVal_ax[1]*10000.0F)
    ));
  }

  if(NULL != v_EolSensor_po)
  {
    EOL_DEBUG_PRINTF(("ppx*10k:%d,ppy*10k:%d\n",static_cast<sint32_t>(v_EolSensor_po->getPpp_rx().getPosX()*10000.0F),static_cast<sint32_t>(v_EolSensor_po->getPpp_rx().getPosY()*10000.0F)));
  }

  if (NULL != v_EolLensRadial_po)
  {
    EOL_DEBUG_PRINTF(("W2I[0]*100K: %d, W2I[1]*100K: %d, W2I[2]*100K: %d, W2I[3]*100K: %d, W2I[4]*100K: %d, W2I[5]*100K: %d\n",
        static_cast<sint32_t>(v_EolLensRadialCfg_s.world2image_x[0] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.world2image_x[1] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.world2image_x[2] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.world2image_x[3] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.world2image_x[4] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.world2image_x[5] * 100000.0F)
    ));
    EOL_DEBUG_PRINTF(("I2W[0]*100K: %d, I2W[1]*100K: %d, I2W[2]*100K: %d, I2W[3]*100K: %d, I2W[4]*100K: %d, I2W[5]*100K: %d\n, ",
        static_cast<sint32_t>(v_EolLensRadialCfg_s.image2world_x[0] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.image2world_x[1] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.image2world_x[2] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.image2world_x[3] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.image2world_x[4] * 100000.0F),
        static_cast<sint32_t>(v_EolLensRadialCfg_s.image2world_x[5] * 100000.0F)
    ));
  }
#endif
  eolAlgoState_e = shmdata::e_EolConfigureAlgoView;
  dataProvider_ro.setAlgoState_v( eolAlgoState_e );
}


void JobEol::dump_v()
{
}

void JobEol::sendAlgoView_v(const uint8_t *i_Img_pu8, const uint32_t i_ImgSize_u32, const char *i_ImgName_pc) const
{
  uint32_t v_TempCounter_u32 = 0U;
  app::App::setBlocked_v();
  while (logging::ILogSender::e_IbpComplete != log_ro.logBin_e(i_Img_pu8, i_ImgSize_u32,i_ImgName_pc,
      logging::ILogSender::e_Force, logging::LogCtx::c_LogCtxDefault_u32))
  {
    ++v_TempCounter_u32;
    if (100U == v_TempCounter_u32)
    {
      break;
    }
  }
  app::App::setUnBlocked_v();
}

void JobEol::initTargetLimits_v(CameraId_t i_McuCamId_e)
{
  const float32_t c_EolImgPatternX_f32 = 647.7F; // 8.5Fx3.0Fx25.4F
  const float32_t c_EolImgOffsetX_f32 = 107.95F; // 0.5Fx8.5Fx25.4F
  sint8_t v_TargetIndex_s8 = 0; // Init
  uint8_t v_ConnectorIdRear_u8 = dataProvider_ro.getCameraConnectorIdFromMcuId_u8(prjcontainer::e_Rear);
  const shmdata::EolConfig_s& c_EolCfgData_rs = dataProvider_ro.getEolConfigData_s();
#ifdef EOL_HARDCODED_INPUT_IMAGE
  mecl::Camera_t &v_CameraRear_ro = dataProvider_ro.accessAdapterCameraReal_ro().accessCamera_rt(v_ConnectorIdRear_u8, prjcontainer::AdapterCameraReal::e_ExtrDesign, prjcontainer::AdapterCameraReal::e_IntrDefault, prjcontainer::AdapterCameraReal::e_LensDefault, false);
#else
  mecl::Camera_t &v_CameraRear_ro = dataProvider_ro.accessAdapterCameraReal_ro().accessCamera_rt(v_ConnectorIdRear_u8, prjcontainer::AdapterCameraReal::e_ExtrDesign, prjcontainer::AdapterCameraReal::e_IntrCurrent, prjcontainer::AdapterCameraReal::e_LensCurrent, true);
#endif

  //Couldn't be fixed with eol, related to mecl
  //PRQA S 3077 1
  mecl::model::Pinhole<float32_t> &v_PinHole_rx = dynamic_cast<mecl::model::Pinhole<float32_t>&>(v_CameraRear_ro.getImager_rx());
  mecl::core::Point3D<float32_t> v_T_o = v_PinHole_rx.getTranslationVector_x();
  v_T_o = v_PinHole_rx.getCameraCenter_x(v_T_o);

  v_TargetIndex_s8 = static_cast<sint8_t>((v_T_o(0) - c_EolImgOffsetX_f32)/c_EolImgPatternX_f32);

  switch(i_McuCamId_e)
  {
    case prjcontainer::e_Front:
    {
      eolInitData_ps->targetLimitF_s8 = -3;
      eolInitData_ps->targetInit_s8 = -2;
      eolInitData_ps->targetLimitR_s8 = c_EolCfgData_rs.frontCamTargetLimitR_s8;
      break;
    }
    case prjcontainer::e_Left:
    {
      eolInitData_ps->targetLimitF_s8 = -1;
      eolInitData_ps->targetInit_s8 = 0;
      eolInitData_ps->targetLimitR_s8 = 7;
      break;
    }
    case prjcontainer::e_Rear:
    {
      eolInitData_ps->targetLimitF_s8 = v_TargetIndex_s8 + 1;
      eolInitData_ps->targetInit_s8 = v_TargetIndex_s8 + 2;
      if ((v_TargetIndex_s8 + 4) <= c_EolCfgData_rs.rearCamMaxTargetLimitR_s8)
      {
        eolInitData_ps->targetLimitR_s8 = v_TargetIndex_s8 + 4;
      }
      else
      {
        eolInitData_ps->targetLimitR_s8 = c_EolCfgData_rs.rearCamMaxTargetLimitR_s8;
      }
      break;
    }
    case prjcontainer::e_Right:
    {
      eolInitData_ps->targetLimitF_s8 = -1;
      eolInitData_ps->targetInit_s8 = 0;
      eolInitData_ps->targetLimitR_s8 = 7;
      break;
    }
    default:
    {
      eolInitData_ps->targetLimitF_s8 = -3;
      eolInitData_ps->targetInit_s8 = -2;
      eolInitData_ps->targetLimitR_s8 = c_EolCfgData_rs.defaultCamTargetLimitR_s8;
      break;
    }
  }

  EOL_DEBUG_PRINTF(("TargetLmtF: %d, TargetInit: %d, TargetLmtR: %d\n", eolInitData_ps->targetLimitF_s8, eolInitData_ps->targetInit_s8, eolInitData_ps->targetLimitR_s8));
}

} /* namespace eol */

