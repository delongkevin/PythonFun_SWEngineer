    v_PinholeCfg64_s.extrinsic_s.rotationType_e = c_Extrinsics32_rs.rotationType_e;

    v_PinholeCfg64_s.intrinsic_s.foclX_x = static_cast<float64_t>(c_Intrinsics32_rs.foclX_x);
    v_PinholeCfg64_s.intrinsic_s.foclY_x = static_cast<float64_t>(c_Intrinsics32_rs.foclY_x);
    v_PinholeCfg64_s.intrinsic_s.pppCfg_x.cVal_ax[0] =  static_cast<float64_t>(c_Intrinsics32_rs.pppCfg_x.cVal_ax[0]);
