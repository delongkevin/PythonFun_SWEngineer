    v_PinholeCfg64_s.extrinsic_s.eulerAngles_s.yaw_x = static_cast<float64_t>(c_Extrinsics32_rs.eulerAngles_s.yaw_x);
    v_PinholeCfg64_s.extrinsic_s.eulerAngles_s.roll_x = static_cast<float64_t>(c_Extrinsics32_rs.eulerAngles_s.roll_x);
    v_PinholeCfg64_s.extrinsic_s.pos_x.cVal_ax[0] = static_cast<float64_t>(c_Extrinsics32_rs.pos_x.cVal_ax[0]);
    v_PinholeCfg64_s.extrinsic_s.pos_x.cVal_ax[1] = static_cast<float64_t>(c_Extrinsics32_rs.pos_x.cVal_ax[1]);
    v_PinholeCfg64_s.extrinsic_s.pos_x.cVal_ax[2] = static_cast<float64_t>(c_Extrinsics32_rs.pos_x.cVal_ax[2]);
