    mecl::core::Point2D<float32_t>::Config_s v_PszPxCfg_s = { 0.003f, 0.003f };

    // Define configuration for common sensor
    mecl::model::Sensor<float32_t>::Config_s v_sensorCfg_s = { v_PppPxCfg_s, v_PszPxCfg_s, mecl::model::e_UpperLeft, {0.0F, 0.0F}, {1279.0F, 799.0F} };

