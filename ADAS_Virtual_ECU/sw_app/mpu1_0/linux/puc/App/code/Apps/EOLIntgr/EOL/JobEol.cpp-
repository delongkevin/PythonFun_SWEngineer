    mecl::core::Point3D<float32_t>::Config_s v_LeftCfg_s  = {856.18F, -1032.63F, 1296.50F};//{jobeol.eolcalib_o.lCali_V_Calibration_s.CamX_f32, jobeol.eolcalib_o.lCali_V_Calibration_s.CamY_f32, jobeol.eolcalib_o.lCali_V_Calibration_s.CamZ_f32};//{850.59  ,-1027.91, 1301.00};//{856.18F, -1032.63F, 1296.50F};
    mecl::core::Point3D<float32_t>::Config_s v_RearCfg_s  = {5417.39F,0.00F,1423.66F};//{4265.50 ,0.00 ,1093.74};//{5717.34, 0.0F, 1429.22F};
    mecl::core::Point3D<float32_t>::Config_s v_RightCfg_s = {882.50F, 1035.49F, 1293.95F};//{850.58  ,1027.88 ,1301.29};//{882.50F, 1035.49F, 1293.95F};

    mecl::core::RotationMatrix<float32_t>::EulerAngles_s v_FrontEulerAngles_s = {mecl::math::toRadians_x<float32_t>(62.94F), 0, 0};
    mecl::core::RotationMatrix<float32_t>::EulerAngles_s v_LeftEulerAngles_s  = {mecl::math::toRadians_x<float32_t>(49.59F), mecl::math::toRadians_x<float32_t>(-21.94), mecl::math::toRadians_x<float32_t>(17.20)};
