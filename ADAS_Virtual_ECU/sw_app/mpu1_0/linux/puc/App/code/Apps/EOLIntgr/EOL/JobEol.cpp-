    pinhole64_o.updateConfig_v(v_PinholeCfg64_s);
    camera64_o.setImager_v(pinhole64_o);

    v_SensorCfg64_s.pppCfg_x.cVal_ax[0] = static_cast<float64_t>(v_SensorConfig32_s.pppCfg_x.cVal_ax[0]);
    v_SensorCfg64_s.pppCfg_x.cVal_ax[1] = static_cast<float64_t>(v_SensorConfig32_s.pppCfg_x.cVal_ax[1]);
    v_SensorCfg64_s.pszCfg_x.cVal_ax[0] = static_cast<float64_t>(v_SensorConfig32_s.pszCfg_x.cVal_ax[0]);
