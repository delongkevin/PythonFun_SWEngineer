/*
 * Utility API used to add a graph parameter from a node, node parameter index
 */
static void add_graph_parameter_by_node_index(vx_graph graph, vx_node node,
    vx_uint32 node_parameter_index)
{
    vx_parameter parameter = vxGetParameterByIndex(node, node_parameter_index);

    vxAddParameterToGraph(graph, parameter);
    vxReleaseParameter(&parameter);
}

/**
 * @brief   Create capture interface
 */
static vx_status app_create_capture(app_data_t *obj)
{
    vx_status status = VX_SUCCESS;
    tivx_capture_params_t capture_params;
    uint32_t buf_id, loop_id;

    /* Creating exemplar to use for raw image */
    obj->sample_raw_img = tivxCreateRawImage(obj->context, &(sensorParams.sensorInfo.raw_params));
    if ((status = vxGetStatus((vx_reference)obj->sample_raw_img)) != VX_SUCCESS)
    {
        APP_PRINTF("sample_raw_img create failed\n");
    }

    /* Creating object arrays to be used as output to capture node */
    for (buf_id = 0; buf_id < PIPE_DEPTH; buf_id++)
    {
        obj->capt_frames[buf_id] = vxCreateObjectArray(obj->context, (vx_reference)obj->sample_raw_img, NUM_CAPT_CHANNELS);
        if ((status = vxGetStatus((vx_reference)obj->capt_frames[buf_id])) != VX_SUCCESS)
        {
            TRACE(ERROR, _x("obj->capt_frames[#%d] create failed: %X"), buf_id, status);
            return status;
        }
    }

    tivxReleaseRawImage(&obj->sample_raw_img);

    /* Capture initialization */
    tivx_capture_params_init(&capture_params);
    capture_params.numInst                          = 1U;
    capture_params.numCh                            = NUM_CAPT_CHANNELS;
    capture_params.instId[0U]                       = CAPT_INST_ID;
    capture_params.instCfg[0U].enableCsiv2p0Support = (uint32_t)vx_true_e;
    capture_params.instCfg[0U].numDataLanes         = sensorParams.sensorInfo.numDataLanes;
    capture_params.instCfg[0U].numPixelsStrm0       = (uint32_t)1U;
    for (loop_id = 0U; loop_id < capture_params.instCfg[0U].numDataLanes; loop_id++)
    {
        capture_params.instCfg[0U].dataLanesMap[loop_id] = sensorParams.sensorInfo.dataLanesMap[loop_id];
    }

    obj->capture_param_obj = vxCreateUserDataObject(obj->context, "tivx_capture_params_t", sizeof(tivx_capture_params_t), &capture_params);
    if ((status = vxGetStatus((vx_reference)obj->capture_param_obj)) != VX_SUCCESS)
    {
        TRACE(ERROR, _x("capture_param_obj create failed: %X"), status);
        return status;
    }

    obj->captureNode = tivxCaptureNode(obj->capture_graph, obj->capture_param_obj, obj->capt_frames[0]);
    if ((status = vxGetStatus((vx_reference)obj->captureNode)) != VX_SUCCESS)
    {
        TRACE(ERROR, _x("captureNode create failed: %X"), status);
        return status;
    }

    vxSetNodeTarget(obj->captureNode, VX_TARGET_STRING, TIVX_TARGET_CAPTURE1);
    vxSetReferenceName((vx_reference)obj->captureNode, "Capture_node");

    return status;
}

