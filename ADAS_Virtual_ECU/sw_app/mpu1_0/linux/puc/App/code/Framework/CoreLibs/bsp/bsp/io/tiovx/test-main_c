    obj->params.mux_output3      = 0;
    obj->params.mux_output4      = 3;
    obj->params.h3a_in           = 3;
    obj->params.h3a_aewb_af_mode = 0;
    obj->params.chroma_mode      = 0;
    obj->params.enable_ctx       = 1;
    obj->params.bypass_nsf4      = 0;
