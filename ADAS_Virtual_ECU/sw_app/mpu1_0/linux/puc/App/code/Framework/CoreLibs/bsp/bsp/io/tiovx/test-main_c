/**
 * @brief   Create texture wrapping external buffer
 */
static int app_create_texture(screen_context_t ctx, tivx_obj_desc_image_t *desc, app_tex_desc_t *texdesc, int render)
{
    screen_pixmap_t     pixmap;
    screen_buffer_t     buffer;
    int                 val, stride, format, offset[3];
    int                 size[2], buf_size;
    uint8_t            *addr[3];
    int                 r;

    /* ...pixmap creation */
    if ((r = screen_create_pixmap(&pixmap, ctx)) != 0)
    {
        TRACE(ERROR, _x("failed to create pixmap: %d"), r);
        return -(errno = ENOMEM);
    }

    val = SCREEN_USAGE_OPENGL_ES3 | SCREEN_USAGE_WRITE | SCREEN_USAGE_NATIVE | SCREEN_USAGE_READ;
    if ((r = screen_set_pixmap_property_iv(pixmap, SCREEN_PROPERTY_USAGE, &val)) != 0)
    {
        TRACE(ERROR, _x("failed to set pixmap property: %d"), r);
        goto error;
    }

    size[0] = desc->width;
    size[1] = desc->height;

    switch (desc->format)
    {
    case VX_DF_IMAGE_NV12:
        format = SCREEN_FORMAT_NV12;
        stride = desc->imagepatch_addr[0].stride_y;
        buf_size = (stride * desc->height * 3) / 2;
        size[0] = stride;
        size[1] = desc->height;
        break;
    case VX_DF_IMAGE_RGBX:
    case TIVX_DF_IMAGE_BGRX:
        format = SCREEN_FORMAT_RGBA8888;
        stride = desc->imagepatch_addr[0].stride_y;
        buf_size = (stride * desc->height);
        break;
    case VX_DF_IMAGE_YUYV:
        format = SCREEN_FORMAT_YUY2;
        stride = desc->imagepatch_addr[0].stride_y;;
        buf_size = (stride * desc->height);
        break;
    case VX_DF_IMAGE_UYVY:
        format = SCREEN_FORMAT_UYVY;
        stride = desc->imagepatch_addr[0].stride_y;;
        buf_size = (stride * desc->height);
        break;
    default:
        TRACE(ERROR, _x("invalid buffer format: %X"), desc->format);
        goto error;
    }

    TRACE(1, _b("create texture: %d*%d, format=%X, stride=%d, size=%d"), size[0], size[1], format, stride, buf_size);
    
    if ((r = screen_set_pixmap_property_iv(pixmap, SCREEN_PROPERTY_FORMAT, &format)) != 0)
    {
        TRACE(ERROR, _x("failed to set format: %d"), r);
        goto error;
    }

    if ((r = screen_set_pixmap_property_iv(pixmap, SCREEN_PROPERTY_BUFFER_SIZE, size)) != 0)
    {
        TRACE(ERROR, _x("failed to set size: %d"), r);
        goto error;
    }

    /* ...create buffer for a pixmap */
    if ((r = screen_create_buffer(&buffer)) != 0)
    {
        TRACE(ERROR, _x("failed to create buffer: %d"), r);
        goto error;
    }

    if ((r = screen_set_buffer_property_iv(buffer, SCREEN_PROPERTY_SIZE, &buf_size)) != 0)
    {
        TRACE(ERROR, _x("failed to set buffer size: %d"), r);
        goto error;
    }

    if ((r = screen_set_buffer_property_iv(buffer, SCREEN_PROPERTY_BUFFER_SIZE, size)) != 0)
    {
        TRACE(ERROR, _x("failed to set buffer dimensions: %d"), r);
        goto error;
    }

    if ((r = screen_set_buffer_property_iv(buffer, SCREEN_PROPERTY_FORMAT, &format)) != 0)
    {
        TRACE(ERROR, _x("failed to set buffer format: %d"), r);
        goto error;
    }

    if ((r = screen_set_buffer_property_iv(buffer, SCREEN_PROPERTY_STRIDE, &stride)) != 0)
    {
        TRACE(ERROR, _x("failed to set buffer stride: %d"), r);
        goto error;
    }

    val = 1;
    if ((r = screen_set_buffer_property_iv(buffer, SCREEN_PROPERTY_PHYSICALLY_CONTIGUOUS, &val)) != 0)
    {
        TRACE(ERROR, _x("failed to set buffer property: %d"), r);
        goto error;
    }

    addr[0] = tivxMemShared2TargetPtr(&desc->mem_ptr[0]);
    addr[1] = tivxMemShared2TargetPtr(&desc->mem_ptr[1]);
    addr[2] = tivxMemShared2TargetPtr(&desc->mem_ptr[2]);
    
    offset[0] = 0;
    offset[1] = (addr[1] ? (int)(addr[1] - addr[0]) : 0);
    offset[2] = (addr[2] ? (int)(addr[2] - addr[0]) : 0);
    
    if ((r = screen_set_buffer_property_iv(buffer, SCREEN_PROPERTY_PLANAR_OFFSETS, offset)) != 0)
    {
        TRACE(ERROR, _x("failed to set buffer offsets: %d"), r);
        goto error;
    }

    if ((r = screen_set_buffer_property_pv(buffer, SCREEN_PROPERTY_POINTER, (void **)addr)) != 0)
    {
        TRACE(ERROR, _x("failed to set buffer pointers: %d"), r);
        goto error;
    }

    /* ...attach buffer to pixmap */
    if ((r = screen_attach_pixmap_buffer(pixmap, buffer)) != 0)
    {
        TRACE(ERROR, _x("failed to set buffer pointers: %d"), r);
        goto error;
    }

    texdesc->addr = addr[0];

    return 0;
    
error:
    /* ...destroy pixmap created */
    (pixmap != NULL ? screen_destroy_pixmap(pixmap) : 0);
    
    return -(errno = EINVAL);
}


/*******************************************************************************
 * Local buffers handling
 ******************************************************************************/

typedef struct app_buffer_s {

    vx_reference image;


} app_buffer_t;

typedef struct app_buffer_queue_s {

    pthread_mutex_t     lock;

    pthread_cond_t      wait;

    app_buffer_t buffers[PIPE_DEPTH];

    int in_queue[PIPE_DEPTH];

    int in_queue_num;

    int last_filled;

    int last_taken;

} app_buffer_queue_t;

app_buffer_queue_t *ready_queue;
app_buffer_queue_t *busy_queue;

int app_get_buffer(app_buffer_queue_t *queue, app_buffer_t *buffer)
{
    int i;

    pthread_mutex_lock(&queue->lock);

    while (queue->in_queue_num < 1)
    {
        pthread_cond_wait(&queue->wait, &queue->lock);
    }

    for (i = 0; i < PIPE_DEPTH; i++)
    {
        if (queue->in_queue[queue->last_taken])
        {
            queue->in_queue[queue->last_taken] = 0;
            queue->in_queue_num--;
            *buffer = queue->buffers[queue->last_taken];
            queue->last_taken = (queue->last_taken + 1) % PIPE_DEPTH;

            break;
        }
    }

    pthread_mutex_unlock(&queue->lock);

    if (i < PIPE_DEPTH)
    {
        return 1;
    }

    return 0;
}


int app_put_buffer(app_buffer_queue_t *queue, app_buffer_t *buffer)
{
    int i = 0;

    pthread_mutex_lock(&queue->lock);

    for (i = 0; i < PIPE_DEPTH; i++)
    {
        if (!queue->in_queue[queue->last_filled])
        {
            queue->in_queue[queue->last_filled] = 1;
            queue->buffers[queue->last_filled] = *buffer;
            queue->in_queue_num++;
            pthread_cond_signal(&queue->wait);
            queue->last_filled = (queue->last_filled + 1) % PIPE_DEPTH;
            break;
        }
    }

    pthread_mutex_unlock(&queue->lock);

    if (i == PIPE_DEPTH)
    {
        return -1;
    }

    return 0;
}

/**
 * @brief   Display thread
 */
static void * app_display_thread(void *arg)
{
    app_data_t *obj = arg;
    int         i;
    vx_status status = VX_SUCCESS;
    tivx_display_params_t display_params;
    vx_uint32 posX, posY, pipeId;
    vx_graph_parameter_queue_params_t graph_parameters_queue_params_list_display[1];
    uint32_t num_refs;
    app_buffer_t used_buffer;
    vx_user_data_object csitx_config;
    tivx_csitx_params_t local_csitx_config;
    uint32_t loopCnt;

    obj->graph_display = vxCreateGraph(obj->context);
    if (vxGetStatus((vx_reference)obj->graph_display) != VX_SUCCESS)
    {
        APP_PRINTF("graph_display create failed\n");
        return NULL;
    }

    posX      = 0;
    posY      = 0;
    pipeId    = 0;

#if !defined (APP_USE_CSITX)
    /* Display initialization */
    memset(&display_params, 0, sizeof(tivx_display_params_t));
    display_params.opMode = TIVX_KERNEL_DISPLAY_ZERO_BUFFER_COPY_MODE;
    display_params.pipeId = pipeId;
    display_params.outWidth = obj->outWidth;
    display_params.outHeight = obj->outHeight;
    display_params.posX = posX;
    display_params.posY = posY;

    obj->display_param_obj = vxCreateUserDataObject(obj->context, "tivx_display_params_t",
                                                    sizeof(tivx_display_params_t), &display_params);
    if (vxGetStatus((vx_reference)obj->display_param_obj) != VX_SUCCESS)
    {
        APP_PRINTF("display_param_obj create failed\n");
        return NULL;
    }

    obj->displayNode = tivxDisplayNode(obj->graph_display, obj->display_param_obj, obj->output_image[0]);
    if (vxGetStatus((vx_reference)obj->display_param_obj) != VX_SUCCESS)
    {
        APP_PRINTF("displayNode create failed\n");
        return NULL;
    }

    vxSetNodeTarget(obj->displayNode, VX_TARGET_STRING, TIVX_TARGET_DISPLAY1);
#else
    /* CSITX Config initialization */
    tivx_csitx_params_init(&local_csitx_config);
    local_csitx_config.numInst                          = 1U;
    local_csitx_config.numCh                            = 1U;
    local_csitx_config.instId[0U]                       = 0U;
    local_csitx_config.instCfg[0U].rxCompEnable         = (uint32_t)vx_true_e;
    local_csitx_config.instCfg[0U].rxv1p3MapEnable      = (uint32_t)vx_true_e;
    local_csitx_config.instCfg[0U].laneBandSpeed        = TIVX_CSITX_LANE_BAND_SPEED_770_TO_870_MBPS;
    local_csitx_config.instCfg[0U].numDataLanes         = 4U;
    for (loopCnt = 0U; loopCnt < local_csitx_config.instCfg[0U].numDataLanes; loopCnt++)
    {
        local_csitx_config.instCfg[0U].lanePolarityCtrl[loopCnt] = 0u;
    }
    local_csitx_config.chVcNum[0]   = 0;
    local_csitx_config.chInstMap[0] = 0;

    csitx_config = vxCreateUserDataObject(obj->context, "tivx_csitx_params_t",
                                          sizeof(tivx_csitx_params_t), &local_csitx_config);
    obj->displayNode = tivxCsitxNode(obj->graph_display, csitx_config, obj->output_image[0]);

    vxSetNodeTarget(obj->displayNode, VX_TARGET_STRING, TIVX_TARGET_CSITX);
#endif
    vxSetReferenceName((vx_reference)obj->displayNode, "Display_node");

    /* Setting up pipelining parameters */
    add_graph_parameter_by_node_index(obj->graph_display, obj->displayNode, 1);

    int graph_parameter_num = 0;

    /* Set graph schedule config such that graph parameter @ index 0 is enqueuable */
    graph_parameters_queue_params_list_display[graph_parameter_num].graph_parameter_index = graph_parameter_num;
    graph_parameters_queue_params_list_display[graph_parameter_num].refs_list_size = PIPE_DEPTH;
    graph_parameters_queue_params_list_display[graph_parameter_num].refs_list = (vx_reference*)&obj->output_image[0];
    graph_parameter_num++;

    tivxSetGraphPipelineDepth(obj->graph_display, PIPE_DEPTH);

    /* Schedule mode auto is used, here we don't need to call vxScheduleGraph
     * Graph gets scheduled automatically as refs are enqueued to it
     */
    APP_PRINTF("before vxSetGraphScheduleConfig\n");
    vxSetGraphScheduleConfig(obj->graph_display, VX_GRAPH_SCHEDULE_MODE_QUEUE_AUTO, 1, graph_parameters_queue_params_list_display);
    APP_PRINTF("vxSetGraphScheduleConfig done\n");

    status = vxVerifyGraph(obj->graph_display);
    if (status != VX_SUCCESS)
    {
        APP_PRINTF("graph verification failed\n");
        return NULL;
    }

    APP_PRINTF("app_create_graph exiting\n");

    tivxExportGraphToDot(obj->graph_display, ".", "display");

    /* make current EGL stuff */
    for (i = 0; i < PIPE_DEPTH - 1; i++)
    {
        /* Get available output buffer from busy queue */
        if (!app_get_buffer(busy_queue, &used_buffer))
        {
            APP_PRINTF("Failed to get buffer in display thread\n");
            return NULL;
        }

        /* Enqueue buffer to display graph */
        graph_parameter_num = 0;
        vxGraphParameterEnqueueReadyRef(obj->graph_display, graph_parameter_num, (vx_reference*)&used_buffer.image, 1);
        graph_parameter_num++;
    }

    while (1)
    {
#if defined APP_USE_CSITX
        vx_object_array out_display;
#else
        vx_image out_display;
#endif
        app_buffer_t buf;

        /* Dequeue buffer from display graph */
        graph_parameter_num = 0;
        /* Get output reference, waits until a frame is available */
        vxGraphParameterDequeueDoneRef(obj->graph_display, graph_parameter_num, (vx_reference*)&out_display, 1, &num_refs);
        graph_parameter_num++;

        graph_parameter_num = 0;

        buf.image = (vx_reference)out_display;

        /* Submit output buffer to busy queue */
        if (app_put_buffer(ready_queue, &buf))
        {
            APP_PRINTF("Failed to put buffer in display thread");
            return NULL;
        }

        /* Get available output buffer from busy queue */
        if (!app_get_buffer(busy_queue, &buf))
        {
            APP_PRINTF("Failed to get buffer in display thread");
            return NULL;
        }

        /* Enqueue buffer to display graph */
        graph_parameter_num = 0;
        vxGraphParameterEnqueueReadyRef(obj->graph_display, graph_parameter_num, (vx_reference*)&buf.image, 1);
        graph_parameter_num++;

        if (obj->stop_task)
        {
            break;
        }
    }

    {
#if defined APP_USE_CSITX
        vx_object_array out_display;
#else
        vx_image out_display;
#endif
        vxWaitGraph(obj->graph_display);

        /* Dequeue buf for pipe down */
        for (i = 0; i < PIPE_DEPTH - 1; i++)
        {
            APP_PRINTF("Dequeuing buffers from display graph # %d...\n", i);
            graph_parameter_num = 0;
            vxGraphParameterDequeueDoneRef(obj->graph_display, graph_parameter_num, (vx_reference*)&out_display, 1, &num_refs);
            graph_parameter_num++;
        }
    }

    return NULL;
}

