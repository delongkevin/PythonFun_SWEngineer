                                                     sizeof(tivx_vpac_cogent_hydra3_isp_params_t),
                                                     &obj->params);

    /* Create h3a_aew_af output buffer (uninitialized) */
    vx_user_data_object h3a_stats_init = vxCreateUserDataObject(obj->context, "tivx_statistic_data_t", sizeof(tivx_statistic_data_t), NULL);
    obj->h3a_stats_arr = vxCreateObjectArray(obj->context, (vx_reference)h3a_stats_init, NUM_CAPT_CHANNELS);
    vxReleaseUserDataObject(&h3a_stats_init);

    /* Get sample RAW Image */
    obj->raw_img = (tivx_raw_image) vxGetObjectArrayItem(obj->capt_frames[0], 0);

    img_width  = sensorParams.sensorInfo.raw_params.width;
    img_height = sensorParams.sensorInfo.raw_params.height;

    vx_user_data_object h3a_stats = (vx_user_data_object)vxGetObjectArrayItem(obj->h3a_stats_arr, 0);

    obj->vissNode = tivxVpaccogent_hydra3_ispNode(
        obj->capture_graph,
        obj->viss_configuration,
        obj->raw_img, NULL, NULL,
        obj->viss_nv12_out_img[0], NULL, NULL,
        h3a_stats, NULL);

    if (vxGetStatus((vx_reference)obj->vissNode) != VX_SUCCESS)
