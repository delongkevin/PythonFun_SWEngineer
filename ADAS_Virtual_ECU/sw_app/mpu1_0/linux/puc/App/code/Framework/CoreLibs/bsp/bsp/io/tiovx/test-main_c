static vx_status test_pixmap(app_data_t *app)
{
    uint32_t    v_id_t;
    int         i_CameraID_t = 0;
    int32_t     offset_aau32[PIPE_DEPTH][3];
    void       *buffers_apv[PIPE_DEPTH];
    int32_t     size_au32[2];
    int32_t     stride_au32[3];
    int32_t     bufsize_au32[3];
    int32_t     format_u32;
    
    for (v_id_t = 0U; v_id_t < PIPE_DEPTH; v_id_t++)
    {
        vx_reference    v_outFrame_pv = vxGetObjectArrayItem(app->viss_out_frames[v_id_t], i_CameraID_t);
        vx_status       v_status_t;
        
        if ((v_status_t = vxGetStatus(v_outFrame_pv)) != VX_SUCCESS)
        {
            printf("cam-%u: failed to get output frame-%u\n", i_CameraID_t, v_id_t);
            return v_status_t;
        }
        
        uint16_t                v_objID_u16 = ownReferenceGetObjDescId(v_outFrame_pv);
        tivx_obj_desc_image_t*  v_desc_po;
        tivxGetObjDescList(&v_objID_u16, (tivx_obj_desc_t **)&v_desc_po, 1);

        uint8_t*   v_addr_apu32[3] = {
            (uint8_t*)tivxMemShared2TargetPtr(&v_desc_po->mem_ptr[0]),
            (uint8_t*)tivxMemShared2TargetPtr(&v_desc_po->mem_ptr[1]),
            (uint8_t*)tivxMemShared2TargetPtr(&v_desc_po->mem_ptr[2])
        };

        buffers_apv[v_id_t] = v_addr_apu32[0];
        offset_aau32[v_id_t][0] = 0;
        offset_aau32[v_id_t][1] = (v_addr_apu32[1] ? (uint32_t)(v_addr_apu32[1] - v_addr_apu32[0]) : 0U);
        offset_aau32[v_id_t][2] = (v_addr_apu32[2] ? (uint32_t)(v_addr_apu32[2] - v_addr_apu32[0]) : 0U);

        printf("cam-%u: buf-%d: %p\n", i_CameraID_t, v_id_t, buffers_apv[v_id_t]);

        if (v_id_t == 0U)
        {
            size_au32[0] = v_desc_po->width;
            size_au32[1] = v_desc_po->height;
            stride_au32[0] = v_desc_po->imagepatch_addr[0].stride_y;
            stride_au32[1] = v_desc_po->imagepatch_addr[1].stride_y;
            stride_au32[2] = v_desc_po->imagepatch_addr[2].stride_y;
            bufsize_au32[0] = v_desc_po->mem_size[0];
            bufsize_au32[1] = v_desc_po->mem_size[1];
            bufsize_au32[2] = v_desc_po->mem_size[2];
            format_u32 = (app->is_enable_yuyv ? SCREEN_FORMAT_YUY2 : SCREEN_FORMAT_NV12);
        }

        app_tex_desc_t  texdesc;
        app_create_texture(app->screen_ctx, v_desc_po, &texdesc, 0);
    }

    /* ...create pixmaps */
    BUG(1, _x("break"));
    
    return VX_SUCCESS;
}

/**
 * @brief   Application entry point
 */
int TIOVXmain(void)
{
    app_data_t      *app = &__app;
    
    vx_status status = VX_FAILURE;
    char* sensor_list[ISS_SENSORS_MAX_SUPPORTED_SENSOR];
    vx_uint8 count = 0;
    vx_uint8 selectedSensor = 0xFF;
    vx_graph_parameter_queue_params_t graph_parameters_queue_params_list[2];
    int graph_parameter_num = 0;
    uint32_t num_refs, buf_id;
    uint32_t iteration = 0;
    pthread_mutexattr_t mattr;
    int i;
    int ret;

    if (0) {
        
    struct sigaction sa = {0};
    sa.sa_handler = __int_signal;

    if (sigaction(SIGINT, &sa, 0))
    {
        printf("Can't setup sigaction\n");
        return -1;
    }
    }
    
#if defined (APP_AR0233_SENSOR)
    /* ...set sensor id - tbd; make it a macro of put to config */
    app->sensor_sel = 1;
    app->is_enable_yuyv = 1;
#endif

    /* ...to-be-understood */
    pthread_mutexattr_init(&mattr);
    pthread_mutexattr_settype(&mattr, PTHREAD_MUTEX_RECURSIVE);

    ready_queue = (app_buffer_queue_t *) calloc(1, sizeof(app_buffer_queue_t));
    pthread_cond_init(&ready_queue->wait, NULL);
    pthread_mutex_init(&ready_queue->lock, &mattr);

    busy_queue = (app_buffer_queue_t *) calloc(1, sizeof(app_buffer_queue_t));
    pthread_cond_init(&busy_queue->wait, NULL);
    pthread_mutex_init(&busy_queue->lock, &mattr);
    pthread_mutexattr_destroy(&mattr);

    /* Common runtime initialization */
    status = appCommonInit();

    /* ...TIVX initialization */
    tivxInit();
    tivxHostInit();

    app->context = vxCreateContext();
    if ((status = vxGetStatus((vx_reference)app->context)) != VX_SUCCESS)
    {
        TRACE(ERROR, _x("failed to create context: %X"), status);
        return -1;
    }

    tivxHwaLoadKernels(app->context);
    tivxImagingLoadKernels(app->context);

    memset(availableSensorNames, 0, ISS_SENSORS_MAX_SUPPORTED_SENSOR * ISS_SENSORS_MAX_NAME);
    for (count = 0; count < ISS_SENSORS_MAX_SUPPORTED_SENSOR; count++)
    {
        sensor_list[count] = availableSensorNames[count];
    }
    status = appEnumerateImageSensor(sensor_list, &num_sensors_found);
    if (VX_SUCCESS != status)
    {
        TRACE(ERROR, _x("appCreateImageSensor failed: %X"), status);
        return status;
    }

    selectedSensor = app->sensor_sel;
    if (selectedSensor > (num_sensors_found - 1))
    {
        TRACE(ERROR, _x("invalid sensor selection: %d"), selectedSensor);
        return VX_FAILURE;
    }

    app->sensor_name = sensor_list[selectedSensor];
    TRACE(INIT, _b("sensor selected: %s"), app->sensor_name);

    /* Get sensor parameters */
    memset(&sensorParams, 0, sizeof(sensorParams));
    status = appQueryImageSensor(app->sensor_name, &sensorParams);
    if (VX_SUCCESS != status)
    {
        TRACE(ERROR, _x("appQueryImageSensor returned %d"), status);
        return -1;
    }

    app->inWidth = sensorParams.sensorInfo.raw_params.width;
    app->inHeight = sensorParams.sensorInfo.raw_params.height;
    app->cam_dcc_id = sensorParams.dccId;

    /* ...create execution graph */
    if ((vx_true_e == tivxIsTargetEnabled(TIVX_TARGET_DISPLAY1)) &&
        (vx_true_e == tivxIsTargetEnabled(TIVX_TARGET_CAPTURE1)) &&
        (vx_true_e == tivxIsTargetEnabled(TIVX_TARGET_VPAC_VISS1)))
    {
        app->capture_graph = vxCreateGraph(app->context);
        if ((status = vxGetStatus((vx_reference)app->capture_graph)) != VX_SUCCESS)
        {
            TRACE(ERROR, _x("graph create failed: %X"), status);
            return status;
        }
        vxSetReferenceName((vx_reference)app->capture_graph, "CAPTURE");

        /* ...create capture interface */
        status = app_create_capture(app);
        if (status != VX_SUCCESS)
        {
            TRACE(ERROR, _x("app_create_capture failed: %X"), status);
            return status;
        }

        /* ...create ISP interface */
#if defined APP_USE_COGENT_ISP
        status = app_create_cogente_viss_aewb(app);
#else
        status = app_create_viss_aewb(app);
#endif
        if (status != VX_SUCCESS)
        {
            TRACE(ERROR, _x("ISP creation failed: %X"), status);
            return status;
        }

        /* ...what is the meaninig of the index? - tbd */
        add_graph_parameter_by_node_index(app->capture_graph, app->captureNode, 1);
#if defined APP_USE_COGENT_ISP
        add_graph_parameter_by_node_index(app->capture_graph, app->vissNode, 4);
#else
        add_graph_parameter_by_node_index(app->capture_graph, app->vissNode, 6);
#endif
        /* Set graph schedule config such that graph parameter @ index 0 is enqueuable */
        graph_parameters_queue_params_list[graph_parameter_num].graph_parameter_index = graph_parameter_num;
        graph_parameters_queue_params_list[graph_parameter_num].refs_list_size = PIPE_DEPTH;
        graph_parameters_queue_params_list[graph_parameter_num].refs_list = (vx_reference*)&app->capt_frames[0];
        graph_parameter_num++;

        graph_parameters_queue_params_list[graph_parameter_num].graph_parameter_index = graph_parameter_num;
        graph_parameters_queue_params_list[graph_parameter_num].refs_list_size = PIPE_DEPTH;
        graph_parameters_queue_params_list[graph_parameter_num].refs_list = (vx_reference*)&app->viss_nv12_out_img[0];
        graph_parameter_num++;

        tivxSetGraphPipelineDepth(app->capture_graph, PIPE_DEPTH);

        /* Schedule mode auto is used, here we don't need to call vxScheduleGraph
         * Graph gets scheduled automatically as refs are enqueued to it
         */
        vxSetGraphScheduleConfig(app->capture_graph,
                VX_GRAPH_SCHEDULE_MODE_QUEUE_AUTO,
                                 2+0*graph_parameter_num,
                graph_parameters_queue_params_list
                );

        TRACE(INIT, _b("Verifying capture graph..."));
        status = vxVerifyGraph(app->capture_graph);
        if (status != VX_SUCCESS)
        {
            TRACE(ERROR, _x("graph verification failed: %X"), status);
            return status;
        }

        tivxExportGraphToDot(app->capture_graph, "/tmp", "capture_graph");
        TRACE(INIT, _b("capture graph created"));
    }
    else
    {
        return -1;
    }

    status = appStartImageSensor(app->sensor_name, 0xF);
    if (status != VX_SUCCESS)
    {
        TRACE(ERROR, _x("failed to start sensor: %X"), status);
        return status;
    }

    screen_create_context(&app->screen_ctx, SCREEN_BUFFER_PROVIDER_CONTEXT);

    // Wait for results (temporarily)
    if (1)
    {
        vx_object_array out_capture_frames;
        vx_image        out_viss_image;
        vx_uint32       num_refs;
        int             buf_id;
        
        /* Enqueue buf for pipe up but don't trigger graph execution */
        for (buf_id = 0; buf_id < PIPE_DEPTH; buf_id++)
        {
            vxGraphParameterEnqueueReadyRef(app->capture_graph, 0, (vx_reference*)&app->capt_frames[buf_id], 1);
            vxGraphParameterEnqueueReadyRef(app->capture_graph, 1, (vx_reference*)&app->viss_nv12_out_img[buf_id], 1);
        }

        printf("buffers enqueued: %u\n", num_refs);

        /* Get output reference, waits until a frame is available */
        vxGraphParameterDequeueDoneRef(app->capture_graph, 0, (vx_reference*)&out_capture_frames, 1, &num_refs);
        vxGraphParameterDequeueDoneRef(app->capture_graph, 1, (vx_reference*)&out_viss_image, 1, &num_refs);

        printf("buffers ready: %u\n", num_refs);
    }

    /* ...test_pixmap */
    test_pixmap(app);
    


#if 1    
    app->outWidth = 1920;
    app->outHeight = 480;   
#elif defined APP_USE_FOR_RECORDING
    obj->outWidth = 2048;
    obj->outHeight = 1280;
#else
    obj->outWidth = 1920;
    obj->outHeight = 1080;
#endif

    /* ...output buffers creation */
#if defined APP_USE_CSITX
    app->sample_out_image = vxCreateImage(app->context, app->outWidth, app->outHeight, VX_DF_IMAGE_RGBX);
#endif
    for (i = 0; i < PIPE_DEPTH; i++)
    {
        app_buffer_t buf;

#if defined APP_USE_CSITX
        app->output_image[i] = vxCreateObjectArray(app->context, app->sample_out_image, 1);
#else
        app->output_image[i] = vxCreateImage(app->context, app->outWidth, app->outHeight, TIVX_DF_IMAGE_BGRX);
#endif
        if ((status = vxGetStatus((vx_reference)app->output_image[i])) != VX_SUCCESS)
        {
            TRACE(ERROR, _x("failed to create output-%d: %X"), i, status);
            return status;
        }

        buf.image = (vx_reference)app->output_image[i];

        /* ...put buffer into ready queue list */
        app_put_buffer(ready_queue, &buf);
    }

    /* ...create screen */
    screen_window_t native;
    int             value;
    int             size[2] = { DWidth, DHeight };
    
        
    screen_create_window(&native, app->screen_ctx);
    screen_set_window_property_iv(native, SCREEN_PROPERTY_FORMAT, (value = SCREEN_FORMAT_RGBA8888, &value));
    screen_set_window_property_iv(native, SCREEN_PROPERTY_USAGE, (value = SCREEN_USAGE_OPENGL_ES2, &value));
    screen_set_window_property_iv(native, SCREEN_PROPERTY_SWAP_INTERVAL, (value = 1, &value));
    screen_set_window_property_iv(native, SCREEN_PROPERTY_SIZE, size);

    screen_create_window_buffers(native, 2);
    
    /* Enqueue buf for pipe up but don't trigger graph execution */
    for (buf_id = 0; buf_id < PIPE_DEPTH; buf_id++)
    {
        graph_parameter_num = 0;
        vxGraphParameterEnqueueReadyRef(app->capture_graph, graph_parameter_num, (vx_reference*)&app->capt_frames[buf_id], 1);
        graph_parameter_num++;
        vxGraphParameterEnqueueReadyRef(app->capture_graph, graph_parameter_num, (vx_reference*)&app->viss_nv12_out_img[buf_id], 1);
        graph_parameter_num++;
    }

    /* wait for graph instances to complete, compare output and
     * recycle data buffers, schedule again */
    app_buffer_t current_buffer;
    app_buffer_t prev_buffer;
    int first_time = 1;

    /* ...buffer processing loop */
    while (1)
    {
        vx_object_array     out_capture_frames;
        vx_image            out_viss_image;
        
        graph_parameter_num = 0;

        appPerfPointBegin(&app->total_perf);

        /* Get output reference, waits until a frame is available */
        vxGraphParameterDequeueDoneRef(app->capture_graph, 0, (vx_reference*)&out_capture_frames, 1, &num_refs);
        vxGraphParameterDequeueDoneRef(app->capture_graph, 1, (vx_reference*)&out_viss_image, 1, &num_refs);

        /* Get available output buffer from ready queue */
        if (!app_get_buffer(ready_queue, &current_buffer))
        {
            TRACE(ERROR, _x("failed to get output buffer"));
            return -1;
        }
        

        if (!first_time)
        {
            /* Submit output buffer to busy queue */
            if (app_put_buffer(busy_queue, &prev_buffer))
            {
                APP_PRINTF("Failed to put buffer");
                return -1;
            }
        }

        prev_buffer = current_buffer;

        first_time = 0;
        /* todo: mark frames as busy... do we need that right now? */

        /* todo: check available free frames and submit to graph... do we need that? */
#if 0
        vxGraphParameterEnqueueReadyRef(app->capture_graph, graph_parameter_num, (vx_reference*)&out_capture_frames, 1);
        graph_parameter_num++;
        vxGraphParameterEnqueueReadyRef(app->capture_graph, graph_parameter_num, (vx_reference*)&out_viss_image, 1);
        graph_parameter_num++;
#endif
        appPerfPointEnd(&app->total_perf);

        if (iteration == 300)
        {
            appPerfStatsPrintAll();
            //tivx_utils_graph_perf_print(app->capture_graph);
            //tivx_utils_graph_perf_print(app->graph_display);
            printf("\n");
            appPerfPointPrintFPS(&app->total_perf);
            printf("\n");
            /* after first 'n' iteration reset performance stats */
            appPerfStatsResetAll();
            iteration = 0;
        }

        iteration++;

        if(app->stop_task)
        {
            break;
        }
    }

    /* ensure all graph processing is complete */
    vxWaitGraph(app->capture_graph);

    /* Dequeue buf for pipe down */
    num_refs = 0xFF;
    graph_parameter_num = 0;
    while(num_refs > 0)
    {
        vx_object_array out_capture_frames;

        vxGraphParameterCheckDoneRef(app->capture_graph, graph_parameter_num, &num_refs);
        if(num_refs > 0)
        {
            vxGraphParameterDequeueDoneRef(
                                app->capture_graph,
                                graph_parameter_num,
                                (vx_reference*)&out_capture_frames,
                                1,
                                &num_refs);
        }
    }

    if (pthread_join(app->display_thread, NULL))
    {
        printf("Error while waiting display thread \n");
        return -1;
    }

    appStopImageSensor(app->sensor_name, 0xF);

    tivxHwaUnLoadKernels(app->context);
    APP_PRINTF("tivxHwaUnLoadKernels done\n");

    tivxImagingUnLoadKernels(app->context);
    APP_PRINTF("tivxImagingUnLoadKernels done\n");

    status = vxReleaseContext(&app->context);
    if(VX_SUCCESS == status)
    {
        APP_PRINTF("vxReleaseContext done\n");
    }
    else
    {
        printf("Error: vxReleaseContext returned 0x%x \n", status);
    }

    appDeInitImageSensor(app->sensor_name);

    tivxHostDeInit();
    tivxDeInit();
    appCommonDeInit();

    return 0;
}

