                        <COMPU-METHOD-REF DEST="COMPU-METHOD">/MICROSAR/Csm_swc/DataTypes/CompuMethods/Csm_VerifyResultType</COMPU-METHOD-REF>
                        <DATA-CONSTR-REF DEST="DATA-CONSTR">/MICROSAR/Csm_swc/DataTypes/DataConstrs/Csm_VerifyResultType_Constr</DATA-CONSTR-REF>
                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                      </SW-DATA-DEF-PROPS-CONDITIONAL>
