                  </SW-DATA-DEF-PROPS>
                </IMPLEMENTATION-DATA-TYPE>
                <IMPLEMENTATION-DATA-TYPE UUID="c4991aa4-bf90-43fd-82a7-820b98242944">
                  <SHORT-NAME>Csm_ConfigIdType</SHORT-NAME>
                  <DESC>
                    <L-2 L="FOR-ALL">The data type Csm_ConfigIdType identifies a configuration data set, which is unique within a service.</L-2>
                  </DESC>
                  <CATEGORY>TYPE_REFERENCE</CATEGORY>
