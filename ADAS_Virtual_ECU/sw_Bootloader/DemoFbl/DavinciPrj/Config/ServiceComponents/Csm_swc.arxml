                <IMPLEMENTATION-DATA-TYPE UUID="94889954-f184-45e4-9b3e-d888f4df3ed0">
                  <SHORT-NAME>Csm_VerifyResultType</SHORT-NAME>
                  <DESC>
                    <L-2 L="FOR-ALL">The data type Csm_VerifyResultType indicates the result of a verification operation.</L-2>
                  </DESC>
                  <CATEGORY>TYPE_REFERENCE</CATEGORY>
                  <SW-DATA-DEF-PROPS>
                    <SW-DATA-DEF-PROPS-VARIANTS>
