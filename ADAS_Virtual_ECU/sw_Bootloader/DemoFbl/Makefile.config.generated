
#------------------------------------------------------------------------------
# Version of generated hardware configuration
#------------------------------------------------------------------------------
BRS_GENERATED_HW_CONFIG_VERSION = 392

#------------------------------------------------------------------------------
# Clock frequency of main oscillator (Hz)
#------------------------------------------------------------------------------
MAIN_OSC_CLK = 19200000

#------------------------------------------------------------------------------
# BRS time base clock (MHz)
# This frequency is the CPU clock of the cores.
#------------------------------------------------------------------------------
TIMEBASE_CLOCK = 1000

#------------------------------------------------------------------------------
# Peripheral clock (Hz)
# This frequency is the clock for the on-chip timer used for BRS ms flag.
#------------------------------------------------------------------------------
PERIPH_CLOCK = 19200000

#------------------------------------------------------------------------------
# Tested Derivative: TI TDA4VE88
#------------------------------------------------------------------------------
DERIVATIVE = TDA4VE88

#------------------------------------------------------------------------------
# CPU Core Amount (number of cores)
#------------------------------------------------------------------------------
BRS_CPU_CORE_AMOUNT = 6

#------------------------------------------------------------------------------
# Configured Cores
#------------------------------------------------------------------------------
BRS_CPU_CORE_0_USED = 0
BRS_CPU_CORE_1_USED = 0
BRS_CPU_CORE_2_USED = 0
BRS_CPU_CORE_3_USED = 0
BRS_CPU_CORE_4_USED = 0
BRS_CPU_CORE_5_USED = 0
BRS_CPU_CORE_6_USED = 0
BRS_CPU_CORE_7_USED = 0

#------------------------------------------------------------------------------
# CPU Core
#------------------------------------------------------------------------------
CPU_CORE = CORTEX_R5F

#------------------------------------------------------------------------------
# Instruction Set
#------------------------------------------------------------------------------
INSTRUCTION_SET = ARM

#------------------------------------------------------------------------------
# Floating Point Unit (FPU)
#------------------------------------------------------------------------------
FPU_USED = 1

#------------------------------------------------------------------------------
# Evaluation Board: No Led Support
#------------------------------------------------------------------------------
EVA_BOARD = J721S2

#------------------------------------------------------------------------------
# EcuM Stub
#------------------------------------------------------------------------------
APP_SOURCE_LST += Source\EcuM.c

#------------------------------------------------------------------------------
# vBrs_Lcfg
#------------------------------------------------------------------------------
APP_SOURCE_LST += $(GENDATA_DIR)\vBrs_Lcfg.c
 
#------------------------------------------------------------------------------
# Support of Hardware Security Module (HSM)
#------------------------------------------------------------------------------
BRS_ENABLE_HSM_SUPPORT = 0

#------------------------------------------------------------------------------
# Support of FlashBootLoader (FBL)
#------------------------------------------------------------------------------
BRS_ENABLE_FBL_SUPPORT = 1

#------------------------------------------------------------------------------
# Additional ExceptionTable in RAM
#------------------------------------------------------------------------------
BRS_FBL_EXCEPTIONTABLE_IN_RAM = 0

#------------------------------------------------------------------------------
# First Execution Instance
#------------------------------------------------------------------------------
BRS_FIRST_EXECUTION_INSTANCE = 0

ADDITIONAL_INCLUDES += .
ADDITIONAL_LDFLAGS_FROM_VBRS = -L ti/drvlib
ADDITIONAL_LDFLAGS_FROM_VBRS += -Xlinker --library=ti.csl.init.aer5f
ADDITIONAL_LDFLAGS_FROM_VBRS += -Xlinker --library=ti.csl.aer5f
ADDITIONAL_LDFLAGS_FROM_VBRS += -Xlinker --library=sciclient_direct.aer5f
ADDITIONAL_LDFLAGS_FROM_VBRS += -Xlinker --library=ti.osal.aer5f
ADDITIONAL_LDFLAGS_FROM_VBRS += -Xlinker --library=ti.board.aer5f
ADDITIONAL_LDFLAGS_FROM_VBRS += -Xlinker --library=ti.drv.uart.aer5f
ADDITIONAL_LDFLAGS_FROM_VBRS += -Xlinker --library=ti.drv.i2c.aer5f
ADDITIONAL_LDFLAGS_FROM_VBRS += -Xlinker --library=rm_pm_hal.aer5f


